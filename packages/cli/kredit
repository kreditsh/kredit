#!/usr/bin/env bash
#
# kredit — CLI for the Kredit financial risk management API
#
# Usage:
#   kredit check   --agent=AGT_ID --action=ACTION --cost=COST
#   kredit report  --agent=AGT_ID --txn=TXN_ID --outcome=OUTCOME --cost=COST
#   kredit agents  list --org=ORG_ID
#   kredit agents  create --org=ORG_NAME --name=AGENT_NAME
#   kredit orgs    create --name=ORG_NAME
#   kredit orgs    list
#   kredit score   --agent=AGT_ID
#   kredit wallet  --agent=AGT_ID
#
# Environment:
#   KREDIT_API_KEY  — API key (or set in ~/.kredit/config as api_key=...)
#   KREDIT_API_URL  — Base URL (default: https://api.kredit.sh)

set -euo pipefail

VERSION="0.1.0"

# ── Config resolution ────────────────────────────────────────────────────────

resolve_api_key() {
  if [ -n "${KREDIT_API_KEY:-}" ]; then
    echo "$KREDIT_API_KEY"
    return
  fi

  local config_file="$HOME/.kredit/config"
  if [ -f "$config_file" ]; then
    local key
    key=$(grep -E '^(api_key|KREDIT_API_KEY)=' "$config_file" 2>/dev/null | head -1 | cut -d'=' -f2- | tr -d ' ')
    if [ -n "$key" ]; then
      echo "$key"
      return
    fi
  fi

  echo ""
}

API_KEY=$(resolve_api_key)
BASE_URL="${KREDIT_API_URL:-https://api.kredit.sh}"
BASE_URL="${BASE_URL%/}"

# ── Helpers ──────────────────────────────────────────────────────────────────

die() {
  echo "error: $1" >&2
  exit 1
}

require_api_key() {
  if [ -z "$API_KEY" ]; then
    die "No API key. Set KREDIT_API_KEY or add api_key=... to ~/.kredit/config"
  fi
}

# Format JSON output — use jq if available, otherwise cat as-is
format_json() {
  if command -v jq &>/dev/null; then
    jq .
  else
    cat
  fi
}

# HTTP request with 5s timeout and 2 retries with backoff
api_request() {
  local method="$1"
  local path="$2"
  shift 2
  local data="${1:-}"

  require_api_key

  local url="${BASE_URL}${path}"
  local attempt=0
  local max_retries=2
  local response
  local http_code

  while [ $attempt -le $max_retries ]; do
    local curl_args=(
      --silent
      --show-error
      --max-time 5
      --write-out "\n%{http_code}"
      -H "Authorization: Bearer ${API_KEY}"
      -H "Content-Type: application/json"
      -H "User-Agent: kredit-cli/${VERSION}"
    )

    if [ "$method" = "POST" ] || [ "$method" = "PUT" ]; then
      curl_args+=(-X "$method")
      if [ -n "$data" ]; then
        curl_args+=(-d "$data")
      fi
    elif [ "$method" = "GET" ]; then
      curl_args+=(-X GET)
    fi

    curl_args+=("$url")

    local raw
    raw=$(curl "${curl_args[@]}" 2>&1) || true

    # Last line is the HTTP status code
    http_code=$(echo "$raw" | tail -1)
    response=$(echo "$raw" | sed '$d')

    # Success
    if [[ "$http_code" =~ ^2[0-9][0-9]$ ]]; then
      echo "$response" | format_json
      return 0
    fi

    # Client errors — don't retry
    if [[ "$http_code" =~ ^4[0-9][0-9]$ ]]; then
      echo "error: HTTP $http_code" >&2
      echo "$response" | format_json >&2
      return 1
    fi

    # Server errors or connection failures — retry with backoff
    attempt=$((attempt + 1))
    if [ $attempt -le $max_retries ]; then
      local delay
      delay=$(echo "0.5 * (2 ^ ($attempt - 1))" | bc -l 2>/dev/null || echo "1")
      sleep "$delay"
    fi
  done

  echo "error: Request failed after $((max_retries + 1)) attempts (last HTTP $http_code)" >&2
  echo "$response" | format_json >&2
  return 1
}

DASHBOARD_URL="${KREDIT_DASHBOARD_URL:-https://kredit.sh}"

# ── Login ───────────────────────────────────────────────────────────────────

cmd_login() {
  echo "Logging in to Kredit..."

  # Find a free port
  local port
  port=$(python3 -c "import socket; s=socket.socket(); s.bind(('',0)); print(s.getsockname()[1]); s.close()" 2>/dev/null) || die "Python 3 required for login"

  local token=""
  local login_url="${DASHBOARD_URL}/auth/cli-callback?port=${port}"

  # Start a tiny HTTP server that waits for the callback
  python3 -c "
import http.server, urllib.parse, sys, threading

class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        params = urllib.parse.parse_qs(parsed.query)
        token = params.get('token', [''])[0]
        if token:
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(b'<html><body style=\"font-family:sans-serif;text-align:center;margin-top:80px\"><h2>Logged in to Kredit</h2><p>You can close this window and return to your terminal.</p></body></html>')
            with open('/tmp/.kredit_cli_token', 'w') as f:
                f.write(token)
            threading.Thread(target=self.server.shutdown).start()
        else:
            self.send_response(400)
            self.end_headers()
            self.wfile.write(b'Missing token')
    def log_message(self, *args): pass

server = http.server.HTTPServer(('127.0.0.1', ${port}), Handler)
server.serve_forever()
" &
  local server_pid=$!

  # Open browser
  echo "Opening browser for authentication..."
  if command -v open &>/dev/null; then
    open "$login_url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$login_url"
  else
    echo "Open this URL in your browser:"
    echo "  $login_url"
  fi

  echo "Waiting for authentication..."

  # Wait for the server to finish (max 120 seconds)
  local waited=0
  while kill -0 $server_pid 2>/dev/null; do
    sleep 1
    waited=$((waited + 1))
    if [ $waited -ge 120 ]; then
      kill $server_pid 2>/dev/null
      rm -f /tmp/.kredit_cli_token
      die "Login timed out after 120 seconds"
    fi
  done

  # Read the token
  if [ ! -f /tmp/.kredit_cli_token ]; then
    die "Login failed — no token received"
  fi

  token=$(cat /tmp/.kredit_cli_token)
  rm -f /tmp/.kredit_cli_token

  if [ -z "$token" ]; then
    die "Login failed — empty token"
  fi

  echo "Authenticated. Creating API key..."

  # Create an API key using the JWT
  local response
  response=$(curl --silent --show-error --max-time 10 \
    -X POST \
    -H "Authorization: Bearer ${token}" \
    -H "Content-Type: application/json" \
    "${BASE_URL}/auth/keys" 2>&1) || die "Failed to create API key"

  local api_key
  if command -v jq &>/dev/null; then
    api_key=$(echo "$response" | jq -r '.key // empty')
  else
    api_key=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('key',''))" 2>/dev/null)
  fi

  if [ -z "$api_key" ]; then
    echo "error: Failed to create API key" >&2
    echo "$response" | format_json >&2
    exit 1
  fi

  # Save to ~/.kredit/config
  mkdir -p "$HOME/.kredit"
  echo "api_key=${api_key}" > "$HOME/.kredit/config"
  chmod 600 "$HOME/.kredit/config"

  echo ""
  echo "API key created and saved to ~/.kredit/config"
  echo "Key: ${api_key}"
  echo ""
  echo "You're ready to go. Try: kredit orgs create --name=my-team"
}

cmd_demo() {
  require_api_key

  echo ""
  echo "  ╔═══════════════════════════════════╗"
  echo "  ║       Kredit Demo Simulation      ║"
  echo "  ╚═══════════════════════════════════╝"
  echo ""

  # Create demo org
  echo "Creating demo org..."
  local org_result
  org_result=$(curl -s -X POST "${BASE_URL}/orgs" -H "Authorization: Bearer ${API_KEY}" -H "Content-Type: application/json" -d '{"name":"kredit-demo"}' 2>/dev/null)
  local org_id
  org_id=$(echo "$org_result" | jq -r '.id // empty' 2>/dev/null)
  if [ -z "$org_id" ]; then
    # Org might already exist
    org_id=$(curl -s -H "Authorization: Bearer ${API_KEY}" "${BASE_URL}/orgs" | jq -r '.[] | select(.name=="kredit-demo") | .id' 2>/dev/null)
  fi
  [ -z "$org_id" ] && die "Failed to create demo org"
  echo "  Org: kredit-demo ($org_id)"

  # Create agents
  echo "Creating agents..."
  local agents=() names=()

  _create_demo_agent() {
    local name="$1" priority="$2" balance="$3" budget="$4" max_txn="$5" daily="$6" rules="$7"
    local wallet="{\"balance\":$balance,\"budget\":$budget,\"max_per_txn\":$max_txn,\"daily_spend_limit\":$daily}"
    local body="{\"org_name\":\"kredit-demo\",\"name\":\"$name\",\"priority\":\"$priority\",\"wallet\":$wallet,\"rules\":$rules}"
    local id
    id=$(curl -s -X POST "${BASE_URL}/agents" -H "Authorization: Bearer ${API_KEY}" -H "Content-Type: application/json" -d "$body" | jq -r '.id // empty' 2>/dev/null)
    if [ -n "$id" ]; then
      agents+=("$id")
      names+=("$name")
    fi
  }

  local R_API='[{"name":"API cap","match":"openai.*","max_cost_per_txn":5,"daily_spend_limit":100,"hourly_rate_limit":50},{"name":"Default","match":"*","max_cost_per_txn":10,"daily_spend_limit":200,"hourly_rate_limit":100}]'
  local R_SPEND='[{"name":"Purchase cap","match":"*","max_cost_per_txn":500,"daily_spend_limit":2000,"hourly_rate_limit":20}]'

  _create_demo_agent "research-bot" "critical" 500 500 0 0 "$R_API"
  _create_demo_agent "code-assistant" "high" 200 200 0 0 "$R_API"
  _create_demo_agent "data-scraper" "normal" 100 100 5 100 "$R_API"
  _create_demo_agent "travel-agent" "high" 5000 5000 1000 5000 "$R_SPEND"
  _create_demo_agent "procurement-bot" "normal" 2000 2000 500 2000 "$R_SPEND"

  local total=${#agents[@]}
  echo "  Created $total agents"
  echo ""
  echo "  Open your dashboard to watch in real time:"
  echo "  https://kredit.sh/dashboard"
  echo ""
  echo "  Running 1-hour simulation (Ctrl+C to stop)..."
  echo ""
  printf "  %-6s %-18s %-24s %9s  %-8s  %s\n" "TIME" "AGENT" "ACTION" "COST" "RESULT" "DETAIL"
  echo "  ─────────────────────────────────────────────────────────────────────────────────────"

  local API_ACTIONS=("openai.chat" "openai.embeddings" "anthropic.messages" "serp_api.search" "github.api.repos" "slack.post_message" "datadog.metrics" "postgres.query")
  local SPEND_ACTIONS=("flight.booking" "hotel.booking" "equipment.purchase" "office_supplies.order" "software.license" "catering.order")
  local OUTCOMES=("success" "success" "success" "success" "failure" "partial")

  local START=$(date +%s) END=$(($(date +%s) + 3600)) TX=0

  while [ $(date +%s) -lt $END ]; do
    local IDX=$((RANDOM % total))
    local AID="${agents[$IDX]}" ANAME="${names[$IDX]}"

    local ACTION COST
    if [[ "$ANAME" == travel-* ]] || [[ "$ANAME" == procurement-* ]]; then
      ACTION="${SPEND_ACTIONS[$((RANDOM % ${#SPEND_ACTIONS[@]}))]}"
      COST=$(awk "BEGIN{printf \"%.2f\", (($RANDOM % 49500) + 500) / 100.0}")
    else
      ACTION="${API_ACTIONS[$((RANDOM % ${#API_ACTIONS[@]}))]}"
      COST=$(awk "BEGIN{printf \"%.2f\", (($RANDOM % 500) + 1) / 100.0}")
    fi

    local RESULT
    RESULT=$(curl -s -X POST "${BASE_URL}/check" -H "Authorization: Bearer ${API_KEY}" -H "Content-Type: application/json" -d "{\"agent_id\":\"$AID\",\"action\":\"$ACTION\",\"estimated_cost\":$COST}" 2>/dev/null)
    local TXN_ID STATUS RISK REASON
    TXN_ID=$(echo "$RESULT" | jq -r '.transaction_id // empty' 2>/dev/null)
    STATUS=$(echo "$RESULT" | jq -r '.status' 2>/dev/null)
    REASON=$(echo "$RESULT" | jq -r '.block_reason // ""' 2>/dev/null)

    TX=$((TX + 1))
    local ELAPSED=$(( $(date +%s) - START ))
    local TS=$(printf "%02d:%02d" "$((ELAPSED / 60))" "$((ELAPSED % 60))")

    if [ "$STATUS" = "allowed" ] && [ -n "$TXN_ID" ]; then
      local OC="${OUTCOMES[$((RANDOM % ${#OUTCOMES[@]}))]}"
      local AC=$COST
      [ "$OC" = "failure" ] && AC=$(awk "BEGIN{printf \"%.2f\", $COST * 0.3}")
      curl -s -X POST "${BASE_URL}/report" -H "Authorization: Bearer ${API_KEY}" -H "Content-Type: application/json" -d "{\"transaction_id\":\"$TXN_ID\",\"outcome\":\"$OC\",\"actual_cost\":$AC}" > /dev/null 2>&1
      printf "  %-6s %-18s %-24s \$%8s  %-8s\n" "$TS" "$ANAME" "$ACTION" "$COST" "$OC"
    else
      printf "  %-6s %-18s %-24s \$%8s  %-8s  %s\n" "$TS" "$ANAME" "$ACTION" "$COST" "BLOCKED" "$REASON"
    fi

    sleep $(( (RANDOM % 8) + 3 ))
  done

  echo ""
  echo "  Demo complete: $TX transactions"
  echo "  View results: https://kredit.sh/dashboard"
}

cmd_logout() {
  if [ -f "$HOME/.kredit/config" ]; then
    rm "$HOME/.kredit/config"
    echo "Logged out. API key removed from ~/.kredit/config"
  else
    echo "Not logged in."
  fi
}

cmd_rules() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      local agent=""
      for arg in "$@"; do
        case "$arg" in
          --agent=*) agent="${arg#--agent=}" ;;
          --help) echo "Usage: kredit rules list --agent=AGENT_ID"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$agent" ] && die "Missing --agent"
      api_request GET "/agents/${agent}/rules"
      ;;
    add)
      local agent="" name="" match="*" max_cost=0 daily=0 hourly=0
      for arg in "$@"; do
        case "$arg" in
          --agent=*) agent="${arg#--agent=}" ;;
          --name=*) name="${arg#--name=}" ;;
          --match=*) match="${arg#--match=}" ;;
          --max-cost=*) max_cost="${arg#--max-cost=}" ;;
          --daily=*) daily="${arg#--daily=}" ;;
          --hourly=*) hourly="${arg#--hourly=}" ;;
          --help) echo "Usage: kredit rules add --agent=ID --name=NAME --match=PATTERN --max-cost=N --daily=N --hourly=N"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$agent" ] && die "Missing --agent"
      [ -z "$name" ] && die "Missing --name"
      api_request POST "/agents/${agent}/rules" "{\"name\":\"${name}\",\"match\":\"${match}\",\"max_cost_per_txn\":${max_cost},\"daily_spend_limit\":${daily},\"hourly_rate_limit\":${hourly}}"
      ;;
    remove)
      local agent="" rule=""
      for arg in "$@"; do
        case "$arg" in
          --agent=*) agent="${arg#--agent=}" ;;
          --rule=*) rule="${arg#--rule=}" ;;
          --help) echo "Usage: kredit rules remove --agent=AGENT_ID --rule=RULE_ID"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$agent" ] && die "Missing --agent"
      [ -z "$rule" ] && die "Missing --rule"
      api_request DELETE "/agents/${agent}/rules/${rule}"
      ;;
    --help|help)
      echo "Usage: kredit rules <list|add|remove>"
      echo ""
      echo "  kredit rules list --agent=AGENT_ID"
      echo "  kredit rules add --agent=ID --name=NAME --match=PATTERN --max-cost=N --daily=N --hourly=N"
      echo "  kredit rules remove --agent=AGENT_ID --rule=RULE_ID"
      ;;
    "")
      die "Missing subcommand. Use: kredit rules <list|add|remove>"
      ;;
    *)
      die "Unknown rules subcommand: $subcmd"
      ;;
  esac
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_check() {
  local agent="" action="" cost=""

  for arg in "$@"; do
    case "$arg" in
      --agent=*) agent="${arg#--agent=}" ;;
      --action=*) action="${arg#--action=}" ;;
      --cost=*) cost="${arg#--cost=}" ;;
      --help) echo "Usage: kredit check --agent=AGT_ID --action=ACTION --cost=COST"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$agent" ] && die "Missing --agent"
  [ -z "$action" ] && die "Missing --action"
  [ -z "$cost" ] && die "Missing --cost"

  api_request POST "/check" "{\"agent_id\":\"${agent}\",\"action\":\"${action}\",\"estimated_cost\":${cost}}"
}

cmd_report() {
  local agent="" txn="" outcome="" cost=""

  for arg in "$@"; do
    case "$arg" in
      --agent=*) agent="${arg#--agent=}" ;;
      --txn=*) txn="${arg#--txn=}" ;;
      --outcome=*) outcome="${arg#--outcome=}" ;;
      --cost=*) cost="${arg#--cost=}" ;;
      --help) echo "Usage: kredit report --agent=AGT_ID --txn=TXN_ID --outcome=OUTCOME --cost=COST"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$agent" ] && die "Missing --agent"
  [ -z "$txn" ] && die "Missing --txn"
  [ -z "$outcome" ] && die "Missing --outcome"
  [ -z "$cost" ] && die "Missing --cost"

  api_request POST "/report" "{\"transaction_id\":\"${txn}\",\"outcome\":\"${outcome}\",\"actual_cost\":${cost}}"
}

cmd_agents() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      local org=""
      for arg in "$@"; do
        case "$arg" in
          --org=*) org="${arg#--org=}" ;;
          --help) echo "Usage: kredit agents list --org=ORG_ID"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$org" ] && die "Missing --org"
      api_request GET "/agents?org_id=${org}"
      ;;
    create)
      local org="" name=""
      for arg in "$@"; do
        case "$arg" in
          --org=*) org="${arg#--org=}" ;;
          --name=*) name="${arg#--name=}" ;;
          --help) echo "Usage: kredit agents create --org=ORG_NAME --name=AGENT_NAME"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$org" ] && die "Missing --org"
      [ -z "$name" ] && die "Missing --name"
      api_request POST "/agents" "{\"org_name\":\"${org}\",\"name\":\"${name}\"}"
      ;;
    --help|help)
      echo "Usage: kredit agents <list|create>"
      echo ""
      echo "  kredit agents list --org=ORG_ID"
      echo "  kredit agents create --org=ORG_NAME --name=AGENT_NAME"
      ;;
    "")
      die "Missing subcommand. Use: kredit agents <list|create>"
      ;;
    *)
      die "Unknown agents subcommand: $subcmd"
      ;;
  esac
}

cmd_orgs() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      api_request GET "/orgs"
      ;;
    create)
      local name=""
      for arg in "$@"; do
