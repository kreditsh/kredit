  case "$subcmd" in
    list)
      local mode="" environment_id=""
      for arg in "$@"; do
        case "$arg" in
          --mode=*) mode="${arg#--mode=}" ;;
          --environment-id=*) environment_id="${arg#--environment-id=}" ;;
          --env-id=*) environment_id="${arg#--env-id=}" ;;
          --help) echo "Usage: kredit orgs list [--mode=MODE] [--environment-id=ENV_ID]"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -n "$mode" ] && validate_mode "$mode"
      local query=""
      [ -n "$mode" ] && query="${query}&mode=${mode}"
      [ -n "$environment_id" ] && query="${query}&environment_id=${environment_id}"
      if [ -n "$query" ]; then
        api_request GET "/orgs?${query#&}"
      else
        api_request GET "/orgs"
      fi
      ;;
    create)
      local name="" mode="" environment_id=""
      for arg in "$@"; do
        case "$arg" in
          --name=*) name="${arg#--name=}" ;;
          --mode=*) mode="${arg#--mode=}" ;;
          --environment-id=*) environment_id="${arg#--environment-id=}" ;;
          --env-id=*) environment_id="${arg#--env-id=}" ;;
          --help) echo "Usage: kredit orgs create --name=ORG_NAME [--mode=MODE] [--environment-id=ENV_ID]"; return 0 ;;
