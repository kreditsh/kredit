#!/usr/bin/env bash
#
# kredit — CLI for the Kredit financial risk management API
#
# Usage:
#   kredit check   --agent-id=ID --action=ACTION --estimated-cost=COST [--type=TYPE]
#   kredit report  --transaction-id=ID --outcome=OUTCOME [--actual-cost=COST]
#   kredit agents  list [--org-id=ORG_ID]
#   kredit agents  create --org-name=ORG_NAME --name=AGENT_NAME
#   kredit orgs    create --name=ORG_NAME
#   kredit orgs    list
#   kredit score   --agent-id=ID
#   kredit wallet  --agent-id=ID
#
# Environment:
#   KREDIT_API_KEY  — API key (or set in ~/.kredit/config as api_key=...)
#   KREDIT_API_URL  — Base URL (default: https://api.kredit.sh)

set -euo pipefail

VERSION="0.4.0"

# ── Config resolution ────────────────────────────────────────────────────────

resolve_api_key() {
  if [ -n "${KREDIT_API_KEY:-}" ]; then
    echo "$KREDIT_API_KEY"
    return
  fi

  local config_file="${HOME:-$(eval echo ~)}/.kredit/config"
  if [ -f "$config_file" ]; then
    local key
    key=$(grep -E '^(api_key|KREDIT_API_KEY)=' "$config_file" 2>/dev/null | head -1 | cut -d'=' -f2- | tr -d ' ')
    if [ -n "$key" ]; then
      echo "$key"
      return
    fi
  fi

  echo ""
}

API_KEY=$(resolve_api_key)
BASE_URL="${KREDIT_API_URL:-https://api.kredit.sh}"
BASE_URL="${BASE_URL%/}"

# ── Helpers ──────────────────────────────────────────────────────────────────

die() {
  echo "error: $1" >&2
  exit 1
}

require_api_key() {
  if [ -z "$API_KEY" ]; then
    die "No API key. Set KREDIT_API_KEY or add api_key=... to ~/.kredit/config"
  fi
}

# Resolve the target sandbox id for sandbox-scoped commands (e.g. priors):
#   1) an explicit --sandbox-id flag (passed as $1)
#   2) KREDIT_SANDBOX_ID env var
#   3) sandbox_id=... in ~/.kredit/config
resolve_sandbox_id() {
  if [ -n "${1:-}" ]; then
    echo "$1"
    return
  fi
  if [ -n "${KREDIT_SANDBOX_ID:-}" ]; then
    echo "$KREDIT_SANDBOX_ID"
    return
  fi
  local config_file="${HOME:-$(eval echo ~)}/.kredit/config"
  if [ -f "$config_file" ]; then
    grep -E '^(sandbox_id|KREDIT_SANDBOX_ID)=' "$config_file" 2>/dev/null | head -1 | cut -d'=' -f2- | tr -d ' '
  fi
}

# Modes in promote order: simulation → preview → production.
# Fresh sandboxes land in `simulation`.
validate_mode() {
  case "$1" in
    simulation|preview|production) ;;
    *) die "Invalid --mode: $1. Valid values: simulation, preview, production" ;;
  esac
}

# Format JSON output — use jq if available, otherwise cat as-is
format_json() {
  if command -v jq &>/dev/null; then
    jq .
  else
    cat
  fi
}

# HTTP request with 5s timeout and 2 retries with backoff
api_request() {
  local method="$1"
  local path="$2"
  shift 2
  local data="${1:-}"

  require_api_key

  local url="${BASE_URL}${path}"
  local attempt=0
  local max_retries=2
  local response
  local http_code

  while [ $attempt -le $max_retries ]; do
    local curl_args=(
      --silent
      --show-error
      --max-time 5
      --write-out "\n%{http_code}"
      -H "Authorization: Bearer ${API_KEY}"
      -H "Content-Type: application/json"
      -H "User-Agent: kredit-cli/${VERSION}"
    )

    curl_args+=(-X "$method")
    if [ -n "$data" ]; then
      curl_args+=(-d "$data")
    fi

    curl_args+=("$url")

    local raw
    raw=$(curl "${curl_args[@]}" 2>&1) || true

    # Last line is the HTTP status code
    http_code=$(echo "$raw" | tail -1)
    response=$(echo "$raw" | sed '$d')

    # Success
    if [[ "$http_code" =~ ^2[0-9][0-9]$ ]]; then
      echo "$response" | format_json
      return 0
    fi

    # Client errors — don't retry
    if [[ "$http_code" =~ ^4[0-9][0-9]$ ]]; then
      echo "error: HTTP $http_code" >&2
      echo "$response" | format_json >&2
      return 1
    fi

    # Server errors or connection failures — retry with backoff
    attempt=$((attempt + 1))
    if [ $attempt -le $max_retries ]; then
      local delay
      delay=$(echo "0.5 * (2 ^ ($attempt - 1))" | bc -l 2>/dev/null || echo "1")
      sleep "$delay"
    fi
  done

  echo "error: Request failed after $((max_retries + 1)) attempts (last HTTP $http_code)" >&2
  echo "$response" | format_json >&2
  return 1
}

DASHBOARD_URL="${KREDIT_DASHBOARD_URL:-https://kredit.sh}"

# ── Login ───────────────────────────────────────────────────────────────────

cmd_login() {
  echo "Logging in to Kredit..."

  # Find a free port
  local port
  port=$(python3 -c "import socket; s=socket.socket(); s.bind(('',0)); print(s.getsockname()[1]); s.close()" 2>/dev/null) || die "Python 3 required for login"

  local token=""
  local login_url="${DASHBOARD_URL}/auth/cli-callback?port=${port}"

  # Start a tiny HTTP server that waits for the callback
  python3 -c "
import http.server, urllib.parse, sys, threading

class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        params = urllib.parse.parse_qs(parsed.query)
        token = params.get('token', [''])[0]
        if token:
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(b'<html><body style=\"font-family:sans-serif;text-align:center;margin-top:80px\"><h2>Logged in to Kredit</h2><p>You can close this window and return to your terminal.</p></body></html>')
            with open('/tmp/.kredit_cli_token', 'w') as f:
                f.write(token)
            threading.Thread(target=self.server.shutdown).start()
        else:
            self.send_response(400)
            self.end_headers()
            self.wfile.write(b'Missing token')
    def log_message(self, *args): pass

server = http.server.HTTPServer(('127.0.0.1', ${port}), Handler)
server.serve_forever()
" &
  local server_pid=$!

  # Open browser
  echo "Opening browser for authentication..."
  if command -v open &>/dev/null; then
    open "$login_url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$login_url"
  else
    echo "Open this URL in your browser:"
    echo "  $login_url"
  fi

  echo "Waiting for authentication..."

  # Wait for the server to finish (max 120 seconds)
  local waited=0
  while kill -0 $server_pid 2>/dev/null; do
    sleep 1
    waited=$((waited + 1))
    if [ $waited -ge 120 ]; then
      kill $server_pid 2>/dev/null
      rm -f /tmp/.kredit_cli_token
      die "Login timed out after 120 seconds"
    fi
  done

  # Read the token
  if [ ! -f /tmp/.kredit_cli_token ]; then
    die "Login failed — no token received"
  fi

  token=$(cat /tmp/.kredit_cli_token)
  rm -f /tmp/.kredit_cli_token

  if [ -z "$token" ]; then
    die "Login failed — empty token"
  fi

  echo "Authenticated. Creating API key..."

  # Create an API key using the JWT
  local response
  response=$(curl --silent --show-error --max-time 10 \
    -X POST \
    -H "Authorization: Bearer ${token}" \
    -H "Content-Type: application/json" \
    "${BASE_URL}/auth/keys" 2>&1) || die "Failed to create API key"

  local api_key
  if command -v jq &>/dev/null; then
    api_key=$(echo "$response" | jq -r '.key // empty')
  else
    api_key=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('key',''))" 2>/dev/null)
  fi

  if [ -z "$api_key" ]; then
    echo "error: Failed to create API key" >&2
    echo "$response" | format_json >&2
    exit 1
  fi

  # Save to ~/.kredit/config
  local home="${HOME:-$(eval echo ~)}"
  mkdir -p "$home/.kredit"
  touch "$home/.kredit/config"
  echo "api_key=${api_key}" > "$home/.kredit/config"
  chmod 600 "$home/.kredit/config"

  echo ""
  echo "API key created and saved to ~/.kredit/config"
  echo "Key: ${api_key}"
  echo ""
  echo "You're ready to go. Try: kredit orgs create --name=my-team"
}

# Live realtime simulation. The server owns the engine now — there is no local
# generation. We just start a streaming run and render each action the server
# emits over SSE. Ctrl-C stops the server-side run cleanly.
cmd_simulation() {
  require_api_key

  local sandbox_id="${1:-}" duration="${2:-60}" seed="${3:-42}"

  # Relax strict mode — a single curl/jq hiccup must not kill the stream.
  set +e
  set +u
  set +o pipefail

  # Kick off a realtime, streaming run. duration_sec:0 runs live-to-infinity
  # until stopped. With stream:true the server returns immediately with the id.
  local body="{\"sandbox_id\":\"${sandbox_id}\",\"mode\":\"realtime\",\"duration_sec\":${duration},\"seed\":${seed},\"stream\":true}"
  local resp sim_id
  resp=$(curl -s -X POST "${BASE_URL}/simulations/run" \
    -H "Authorization: Bearer ${API_KEY}" \
    -H "Content-Type: application/json" \
    -d "$body" 2>/dev/null)
  sim_id=$(echo "$resp" | jq -r '.id // empty' 2>/dev/null)
  [ -z "$sim_id" ] && die "Failed to start simulation: $resp"

  # Ctrl-C (or TERM) → stop the server-side run, then leave.
  trap 'echo ""; curl -s -X POST "${BASE_URL}/simulations/${sim_id}/stop" -H "Authorization: Bearer ${API_KEY}" >/dev/null 2>&1; echo "  stopped simulation ${sim_id}"; exit 0' INT TERM

  local horizon="${duration}s"
  [ "$duration" = "0" ] && horizon="live (until stopped)"
  echo ""
  echo "  simulation ${sim_id} — realtime, duration=${horizon}"
  echo "  streaming actions (Ctrl-C to stop)..."
  echo ""
  printf "  %-18s %-24s %10s   %-8s  %s\n" "AGENT" "ACTION" "COST" "STATUS" "REASON"
  echo "  ---------------------------------------------------------------------------------"

  # Stream Server-Sent Events. Each line is `data: {json}`; render `action`
  # events, stop on the terminal `done` event, ignore `ping`s. Keep the auth
  # header on the streaming curl.
  curl -sN "${BASE_URL}/simulations/${sim_id}/stream" \
    -H "Authorization: Bearer ${API_KEY}" \
    -H "User-Agent: kredit-cli/${VERSION}" \
  | while IFS= read -r line; do
      case "$line" in
        data:*) ;;
        *) continue ;;
      esac
      local json="${line#data:}"
      json="${json# }"
      local type
      type=$(printf '%s' "$json" | jq -r '.type // empty' 2>/dev/null)
      case "$type" in
        action)
          local agent action cost status reason
          agent=$(printf '%s'  "$json" | jq -r '.action.agent_name // "-"' 2>/dev/null)
          action=$(printf '%s' "$json" | jq -r '.action.action // "-"' 2>/dev/null)
          cost=$(printf '%s'   "$json" | jq -r '.action.cost // 0' 2>/dev/null)
          status=$(printf '%s' "$json" | jq -r '.action.card.status // "-"' 2>/dev/null)
          reason=$(printf '%s' "$json" | jq -r '.action.card.block_reason // ""' 2>/dev/null)
          printf "  %-18s %-24s \$%9s   %-8s  %s\n" \
            "$agent" "$action" "$cost" "$status" "$reason"
          ;;
        done)
          local total
          total=$(printf '%s' "$json" | jq -r '.total_actions // 0' 2>/dev/null)
          echo "  ---------------------------------------------------------------------------------"
          echo ""
          echo "  done - total actions: ${total}"
          echo ""
          break
          ;;
      esac
    done
}

cmd_logout() {
  local home="${HOME:-$(eval echo ~)}"
  if [ -f "$home/.kredit/config" ]; then
    rm "$home/.kredit/config"
    echo "Logged out. API key removed from ~/.kredit/config"
  else
    echo "Not logged in."
  fi
}

cmd_rules() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      local agent_id=""
      for arg in "$@"; do
        case "$arg" in
          --agent-id=*) agent_id="${arg#--agent-id=}" ;;
          --help) echo "Usage: kredit rules list --agent-id=ID"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$agent_id" ] && die "Missing --agent-id"
      api_request GET "/agents/${agent_id}/rules"
      ;;
    add)
      local agent_id="" name="" match="*" max_cost_per_txn=0 daily_spend_limit=0 hourly_rate_limit=0 mode=""
      for arg in "$@"; do
        case "$arg" in
          --agent-id=*) agent_id="${arg#--agent-id=}" ;;
          --name=*) name="${arg#--name=}" ;;
          --match=*) match="${arg#--match=}" ;;
          --max-cost-per-txn=*) max_cost_per_txn="${arg#--max-cost-per-txn=}" ;;
          --daily-spend-limit=*) daily_spend_limit="${arg#--daily-spend-limit=}" ;;
          --hourly-rate-limit=*) hourly_rate_limit="${arg#--hourly-rate-limit=}" ;;
          --mode=*) mode="${arg#--mode=}" ;;
          --help) echo "Usage: kredit rules add --agent-id=ID --name=NAME --match=PATTERN [--max-cost-per-txn=N] [--daily-spend-limit=N] [--hourly-rate-limit=N] [--mode=MODE]"; echo "  MODE: simulation, preview, production (omit = all modes)"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$agent_id" ] && die "Missing --agent-id"
      [ -z "$name" ] && die "Missing --name"
      [ -n "$mode" ] && validate_mode "$mode"
      api_request POST "/agents/${agent_id}/rules" "{\"name\":\"${name}\",\"match\":\"${match}\",\"max_cost_per_txn\":${max_cost_per_txn},\"daily_spend_limit\":${daily_spend_limit},\"hourly_rate_limit\":${hourly_rate_limit},\"mode\":\"${mode}\"}"
      ;;
    remove)
      local agent_id="" rule_id=""
      for arg in "$@"; do
        case "$arg" in
          --agent-id=*) agent_id="${arg#--agent-id=}" ;;
          --rule-id=*) rule_id="${arg#--rule-id=}" ;;
          --help) echo "Usage: kredit rules remove --agent-id=ID --rule-id=RULE_ID"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$agent_id" ] && die "Missing --agent-id"
      [ -z "$rule_id" ] && die "Missing --rule-id"
      api_request DELETE "/agents/${agent_id}/rules/${rule_id}"
      ;;
    --help|help)
      echo "Usage: kredit rules <list|add|remove>"
      echo ""
      echo "  kredit rules list --agent-id=ID"
      echo "  kredit rules add --agent-id=ID --name=NAME --match=PATTERN [--max-cost-per-txn=N] [--daily-spend-limit=N] [--hourly-rate-limit=N] [--mode=MODE]"
      echo "  kredit rules remove --agent-id=ID --rule-id=RULE_ID"
      ;;
    "")
      die "Missing subcommand. Use: kredit rules <list|add|remove>"
      ;;
    *)
      die "Unknown rules subcommand: $subcmd"
      ;;
  esac
}

# ── Commands ─────────────────────────────────────────────────────────────────

# check runs against ONE environment's state (wallet, counters, score live on
# the env), so --environment-id is required — it names whose state the check
# consumes and mutates.
cmd_check() {
  local agent_id="" action="" estimated_cost="" type="api_call" environment_id=""

  for arg in "$@"; do
    case "$arg" in
      --agent-id=*) agent_id="${arg#--agent-id=}" ;;
      --action=*) action="${arg#--action=}" ;;
      --estimated-cost=*) estimated_cost="${arg#--estimated-cost=}" ;;
      --type=*) type="${arg#--type=}" ;;
      --environment-id=*|--env-id=*) environment_id="${arg#*=}" ;;
      --help) echo "Usage: kredit check --agent-id=ID --action=ACTION --estimated-cost=COST --environment-id=ENV [--type=TYPE]"; echo "  TYPE: api_call (default), mcp_call, compute, data, tool, other"; echo "  ENV:  the environment whose agent state the check runs against"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$agent_id" ] && die "Missing --agent-id"
  [ -z "$action" ] && die "Missing --action"
  [ -z "$estimated_cost" ] && die "Missing --estimated-cost"
  [ -z "$environment_id" ] && die "Missing --environment-id (state and versions live on the environment; see 'kredit environment list')"

  case "$type" in
    api_call|mcp_call|compute|data|tool|other) ;;
    *) die "Invalid --type: $type. Valid values: api_call, mcp_call, compute, data, tool, other" ;;
  esac

  local body="{\"agent_id\":\"${agent_id}\",\"action\":\"${action}\",\"estimated_cost\":${estimated_cost},\"type\":\"${type}\",\"environment_id\":\"${environment_id}\"}"

  api_request POST "/check" "$body"
}

cmd_report() {
  local transaction_id="" outcome="" actual_cost=""

  for arg in "$@"; do
    case "$arg" in
      --transaction-id=*) transaction_id="${arg#--transaction-id=}" ;;
      --outcome=*) outcome="${arg#--outcome=}" ;;
      --actual-cost=*) actual_cost="${arg#--actual-cost=}" ;;
      --help) echo "Usage: kredit report --transaction-id=ID --outcome=OUTCOME [--actual-cost=COST]"; echo "  OUTCOME: success, failure, partial"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$transaction_id" ] && die "Missing --transaction-id"
  [ -z "$outcome" ] && die "Missing --outcome"

  local body="{\"transaction_id\":\"${transaction_id}\",\"outcome\":\"${outcome}\""
  if [ -n "$actual_cost" ]; then
    body="${body},\"actual_cost\":${actual_cost}"
  fi
  body="${body}}"

  api_request POST "/report" "$body"
}

cmd_agents() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      local org_id="" mode="" environment_id=""
      for arg in "$@"; do
        case "$arg" in
          --org-id=*) org_id="${arg#--org-id=}" ;;
          --mode=*) mode="${arg#--mode=}" ;;
          --environment-id=*) environment_id="${arg#--environment-id=}" ;;
          --env-id=*) environment_id="${arg#--env-id=}" ;;
          --help) echo "Usage: kredit agents list [--org-id=ORG_ID] [--mode=MODE] [--environment-id=ENV_ID]"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -n "$mode" ] && validate_mode "$mode"
      local query=""
      [ -n "$org_id" ] && query="${query}&org_id=${org_id}"
      [ -n "$mode" ] && query="${query}&mode=${mode}"
      [ -n "$environment_id" ] && query="${query}&environment_id=${environment_id}"
      if [ -n "$query" ]; then
        api_request GET "/agents?${query#&}"
      else
        api_request GET "/agents"
      fi
      ;;
    create)
      local org_name="" name="" mode="" environment_id=""
      for arg in "$@"; do
        case "$arg" in
          --org-name=*) org_name="${arg#--org-name=}" ;;
          --name=*) name="${arg#--name=}" ;;
          --mode=*) mode="${arg#--mode=}" ;;
          --environment-id=*) environment_id="${arg#--environment-id=}" ;;
          --env-id=*) environment_id="${arg#--env-id=}" ;;
          --help) echo "Usage: kredit agents create --org-name=ORG_NAME --name=AGENT_NAME [--mode=MODE] [--environment-id=ENV_ID]"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$org_name" ] && die "Missing --org-name"
      [ -z "$name" ] && die "Missing --name"
      local body="{\"org_name\":\"${org_name}\",\"name\":\"${name}\""
      if [ -n "$mode" ]; then validate_mode "$mode"; body="${body},\"mode\":\"${mode}\""; fi
      [ -n "$environment_id" ] && body="${body},\"environment_id\":\"${environment_id}\""
      body="${body}}"
      api_request POST "/agents" "$body"
      ;;
    --help|help)
      echo "Usage: kredit agents <list|create>"
      echo ""
      echo "  kredit agents list [--org-id=ORG_ID] [--mode=MODE] [--environment-id=ENV_ID]"
      echo "  kredit agents create --org-name=ORG_NAME --name=AGENT_NAME [--mode=MODE] [--environment-id=ENV_ID]"
      ;;
    "")
      die "Missing subcommand. Use: kredit agents <list|create>"
      ;;
    *)
      die "Unknown agents subcommand: $subcmd"
      ;;
  esac
}

cmd_orgs() {
