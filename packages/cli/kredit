      echo "Usage: kredit orgs <list|create>"
      echo ""
      echo "  kredit orgs list [--mode=MODE] [--environment-id=ENV_ID]"
      echo "  kredit orgs create --name=ORG_NAME [--mode=MODE] [--environment-id=ENV_ID]"
      ;;
    "")
      die "Missing subcommand. Use: kredit orgs <list|create>"
      ;;
    *)
      die "Unknown orgs subcommand: $subcmd"
      ;;
  esac
}

cmd_score() {
  # `kredit score trust --agent-id=ID` recomputes the trust score (control plane).
  local recompute="false"
  if [ "${1:-}" = "trust" ]; then recompute="true"; shift; fi

  local agent_id=""
  for arg in "$@"; do
    case "$arg" in
      --agent-id=*) agent_id="${arg#--agent-id=}" ;;
      --help) echo "Usage: kredit score [trust] --agent-id=ID"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$agent_id" ] && die "Missing --agent-id"
  if [ "$recompute" = "true" ]; then
    api_request POST "/actions/score" "{\"agent_id\":\"${agent_id}\"}"
  else
    api_request GET "/agents/${agent_id}/score"
  fi
}

cmd_wallet() {
  local agent_id=""

  for arg in "$@"; do
    case "$arg" in
      --agent-id=*) agent_id="${arg#--agent-id=}" ;;
      --help) echo "Usage: kredit wallet --agent-id=ID"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$agent_id" ] && die "Missing --agent-id"
  api_request GET "/wallets/${agent_id}"
}

# ── Control-plane verbs (sandboxes, actions, simulation, verify, optimize) ────

# Merge an optional --args='{...}' JSON object into a body's leading "{".
merge_args() {
  local body="$1" extra="$2"
  [ -z "$extra" ] && { echo "$body"; return; }
  extra="${extra#\{}"; extra="${extra%\}}"
  [ -z "$extra" ] && { echo "$body"; return; }
  echo "${body%\}},${extra}}"
}

cmd_sandbox() {
  local subcmd="${1:-}"; shift 2>/dev/null || true
  local id="" name="" version="" args="" include="" source_sim=""
  local positionals=()
  for arg in "$@"; do
    case "$arg" in
      --id=*) id="${arg#--id=}" ;;
      --sandbox-id=*) id="${arg#--sandbox-id=}" ;;
      --name=*) name="${arg#--name=}" ;;
      --version=*) version="${arg#--version=}" ;;
      --args=*) args="${arg#--args=}" ;;
      --include=*) include="${arg#--include=}" ;;
      --source-simulation-id=*) source_sim="${arg#--source-simulation-id=}" ;;
      --help) ;;
      --*) die "Unknown argument: $arg" ;;
      *) positionals+=("$arg") ;;
    esac
  done
  case "$subcmd" in
    list)     api_request GET "/sandboxes" ;;
    get)      [ -z "$id" ] && die "Missing --id"; api_request GET "/sandboxes/${id}" ;;
    create)   [ -z "$name" ] && die "Missing --name"
              api_request POST "/sandboxes" "$(merge_args "{\"name\":\"${name}\"}" "$args")" ;;
    update)   [ -z "$id" ] && die "Missing --id"
              api_request PUT "/sandboxes/${id}" "$(merge_args "{\"name\":\"${name}\"}" "$args")" ;;
    delete)   [ -z "$id" ] && die "Missing --id"; api_request DELETE "/sandboxes/${id}" ;;
    copy)     [ -z "$id" ] && die "Missing --id"
              api_request POST "/sandboxes/${id}/copy" "{\"name\":\"${name}\"}" ;;
    versions) [ -z "$id" ] && die "Missing --id"; api_request GET "/sandboxes/${id}/versions" ;;
    switch)   [ -z "$id" ] && die "Missing --id"; [ -z "$version" ] && die "Missing --version"
              api_request POST "/sandboxes/${id}/switch/${version}" ;;
    promote-preview)    [ -z "$id" ] && die "Missing --id"; api_request POST "/sandboxes/${id}/promote/preview" ;;
    promote-production) [ -z "$id" ] && die "Missing --id"; api_request POST "/sandboxes/${id}/promote/production" ;;
    deploy)
      # Copy a mode's fleet/rules into another mode WITHOUT advancing the active
      # mode pointer (distinct from promote-*, which only moves the pointer).
      [ -z "$id" ] && die "Missing --sandbox-id"
      local from_mode="${positionals[0]:-}" to_mode="${positionals[1]:-}"
      [ -z "$from_mode" ] && die "Missing <from_mode>. Usage: kredit sandbox deploy <from_mode> <to_mode> [--include=orgs,agents,rules] [--sandbox-id=ID]"
      [ -z "$to_mode" ] && die "Missing <to_mode>. Usage: kredit sandbox deploy <from_mode> <to_mode> [--include=orgs,agents,rules] [--sandbox-id=ID]"
      validate_mode "$from_mode"
      validate_mode "$to_mode"
      [ -z "$include" ] && include="orgs,agents,rules"
      local inc_json="[\"$(echo "$include" | sed 's/,/","/g')\"]"
      local body="{\"from_mode\":\"${from_mode}\",\"to_mode\":\"${to_mode}\",\"include\":${inc_json}"
      [ -n "$source_sim" ] && body="${body},\"source_simulation_id\":\"${source_sim}\""
      body="${body}}"
      api_request POST "/sandboxes/${id}/deploy" "$body" ;;
    --help|help|"")
      cat <<'H'
Usage: kredit sandbox <subcommand>
  list | get --id=ID | create --name=NAME [--args='{...}']
  update --id=ID [--name=NAME] [--args='{...}'] | delete --id=ID
  copy --id=ID --name=NAME | versions --id=ID | switch --id=ID --version=N
  promote-preview --id=ID | promote-production --id=PREVIEW_ID
  deploy <from_mode> <to_mode> [--include=orgs,agents,rules] [--sandbox-id=ID] [--source-simulation-id=ID]
    copy a mode's orgs/agents/rules into another mode (does NOT change the active mode)
    modes: simulation → preview → production
H
      ;;
    *) die "Unknown sandbox subcommand: $subcmd" ;;
  esac
}

cmd_sim() {
  local subcmd="${1:-}"; shift 2>/dev/null || true
  local sandbox_id="" mode="predictive" period="1mo" duration="60" budget="0" seed="42" args=""
  local positionals=()
  for arg in "$@"; do
    case "$arg" in
      --sandbox-id=*) sandbox_id="${arg#--sandbox-id=}" ;;
      --mode=*) mode="${arg#--mode=}" ;;
      --period=*) period="${arg#--period=}" ;;
      --duration=*) duration="${arg#--duration=}" ;;
      --monthly-budget=*) budget="${arg#--monthly-budget=}" ;;
      --seed=*) seed="${arg#--seed=}" ;;
      --args=*) args="${arg#--args=}" ;;
      --id=*) sandbox_id="${arg#--id=}" ;;
      --help) ;;
      --*) die "Unknown argument: $arg" ;;
      *) positionals+=("$arg") ;;
    esac
  done
  # "live" is an alias for realtime everywhere
  [ "$mode" = "live" ] && mode="realtime"
  case "$subcmd" in
    live|"")
      # the full live run: a streamed server run through the kredit cycle.
      [ -z "$sandbox_id" ] && die "Missing --sandbox-id (create one with 'kredit init' and add agents first)"
      cmd_simulation "$sandbox_id" "$duration" "$seed" ;;
    stop)
      local sid="${positionals[0]:-$sandbox_id}"
      [ -z "$sid" ] && die "Usage: kredit simulation stop <simulation_id>"
      api_request POST "/simulations/${sid}/stop" ;;
    predictive)
      [ -z "$sandbox_id" ] && die "Missing --sandbox-id (or run 'kredit init sandbox simulation <name>' and set up agents first)"
      local pbody="{\"sandbox_id\":\"${sandbox_id}\",\"mode\":\"predictive\",\"period\":\"${period}\",\"seed\":${seed}}"
      api_request POST "/simulations/run" "$(merge_args "$pbody" "$args")" ;;
    run)
      [ -z "$sandbox_id" ] && die "Missing --sandbox-id"
      local body="{\"sandbox_id\":\"${sandbox_id}\",\"mode\":\"${mode}\",\"period\":\"${period}\",\"duration_sec\":${duration},\"monthly_budget\":${budget},\"seed\":${seed}}"
      api_request POST "/simulations/run" "$(merge_args "$body" "$args")" ;;
    list)
      if [ -n "$sandbox_id" ]; then api_request GET "/simulations?sandbox_id=${sandbox_id}"; else api_request GET "/simulations"; fi ;;
    get)
      [ -z "$sandbox_id" ] && die "Missing --id (simulation id)"; api_request GET "/simulations/${sandbox_id}" ;;
    --help|help)
      cat <<'H'
Usage: kredit simulation [subcommand]
  (none) | live [--sandbox-id=ID]
        run the live simulation — real transactions through the kredit cycle
        (intent → identity → trust → execute → observe → optimize).
        Without --sandbox-id a new sandbox (in simulation mode) is created first.
  predictive --sandbox-id=ID [--period=1d|1wk|2wk|1mo|1quarter|1year] [--seed=N]
        project the sandbox's fleet over a horizon with weekly guardrail optimization
  run  --sandbox-id=ID [--mode=predictive|live] [--period=1mo] [--duration=60] [--seed=N]
  list [--sandbox-id=ID] | get --id=SIM_ID
H
      ;;
    *) die "Unknown simulation subcommand: $subcmd" ;;
  esac
}

# kredit init sandbox simulation <name> — create a sandbox (always starts in
# simulation mode); the container that owns orgs, agents, rules & simulations.
cmd_init() {
  require_api_key
  local what="${1:-}"; shift 2>/dev/null || true
  [ "$what" != "sandbox" ] && die "Usage: kredit init sandbox simulation <name>"
  local stage="${1:-}"
  case "$stage" in
    simulation|preview|production) shift 2>/dev/null || true ;;
  esac
  local name="${1:-}"
  [ -z "$name" ] && die "Usage: kredit init sandbox simulation <name>"
  api_request POST "/sandboxes" "{\"name\":\"${name}\"}"
}

cmd_action() {
  local subcmd="${1:-}"; shift 2>/dev/null || true
  local agent_id="" action="" cost="0" args=""
  for arg in "$@"; do
    case "$arg" in
      --agent-id=*) agent_id="${arg#--agent-id=}" ;;
      --action=*) action="${arg#--action=}" ;;
      --estimated-cost=*) cost="${arg#--estimated-cost=}" ;;
      --args=*) args="${arg#--args=}" ;;
      --help) ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done
  case "$subcmd" in
    intent)
      [ -z "$agent_id" ] && die "Missing --agent-id"; [ -z "$action" ] && die "Missing --action"
      local body="{\"agent_id\":\"${agent_id}\",\"action\":\"${action}\",\"estimated_cost\":${cost}}"
      api_request POST "/actions/intent" "$(merge_args "$body" "$args")" ;;
    --help|help|"")
      echo "Usage: kredit action intent --agent-id=ID --action=KIND.PROVIDER.VERB [--estimated-cost=N]" ;;
    *) die "Unknown action subcommand: $subcmd" ;;
  esac
}

cmd_execute() {
  local kind="${1:-}"; shift 2>/dev/null || true
  local agent_id="" action="" provider="" cost="0" args=""
  for arg in "$@"; do
    case "$arg" in
      --agent-id=*) agent_id="${arg#--agent-id=}" ;;
      --action=*) action="${arg#--action=}" ;;
      --provider=*) provider="${arg#--provider=}" ;;
      --estimated-cost=*) cost="${arg#--estimated-cost=}" ;;
      --args=*) args="${arg#--args=}" ;;
      --help) ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done
  case "$kind" in
    payment|api|tool)
      [ -z "$agent_id" ] && die "Missing --agent-id"
      if [ -z "$action" ]; then
        [ -z "$provider" ] && die "Missing --action or --provider"
        local verb="generate"
        case "$kind" in payment) verb="purchase" ;; tool) verb="query" ;; esac
        action="${kind}.${provider}.${verb}"
      fi
      local body="{\"agent_id\":\"${agent_id}\",\"action\":\"${action}\",\"estimated_cost\":${cost}"
      [ -n "$provider" ] && body="${body},\"provider\":\"${provider}\""
      body="${body}}"
      api_request POST "/actions/execute" "$(merge_args "$body" "$args")" ;;
    --help|help|"")
      echo "Usage: kredit execute <payment|api|tool> --agent-id=ID --provider=NAME [--action=ID] [--estimated-cost=N]" ;;
    *) die "Unknown execute kind: $kind (use payment|api|tool)" ;;
  esac
}

cmd_verify() {
  local what="${1:-}"; shift 2>/dev/null || true
  local agent_id="" provider="skyfire"
  for arg in "$@"; do
    case "$arg" in
      --agent-id=*) agent_id="${arg#--agent-id=}" ;;
      --provider=*) provider="${arg#--provider=}" ;;
      --help) ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done
  case "$what" in
    kya|kyb|kyc)
      [ -z "$agent_id" ] && die "Missing --agent-id"
      api_request POST "/actions/execute" "{\"agent_id\":\"${agent_id}\",\"action\":\"identity.${provider}.verify\",\"type\":\"other\",\"estimated_cost\":0}" ;;
    --help|help|"")
      echo "Usage: kredit verify <kya|kyb|kyc> --agent-id=ID [--provider=skyfire]" ;;
    *) die "Unknown verify type: $what (use kya|kyb|kyc)" ;;
  esac
}

# Identity tokens, issued by a provider (default: kredit itself).
#   kya → agent   (--agent-id | --name | positional)   POST /agents/kya-token
#   kyb → org     (--org-id   | --name | positional)   POST /orgs/kyb-token
#   kyc → account (no subject — the authed user)       POST /account/kyc-token
# A 24-hex positional is treated as an id, anything else as a (sandbox-unique)
# name. The token is shown ONCE; the server stores only a hash.
_identity_token() {
  local kind="$1" id_field="$2" path="$3"; shift 3
  local kind_uc
  kind_uc=$(echo "$kind" | tr '[:lower:]' '[:upper:]')
  local subject_id="" name="" sandbox_id="" provider=""
  for arg in "$@"; do
    case "$arg" in
      "--${id_field}="*) subject_id="${arg#*=}" ;;
      --name=*) name="${arg#--name=}" ;;
      --sandbox-id=*) sandbox_id="${arg#--sandbox-id=}" ;;
      --provider=*) provider="${arg#--provider=}" ;;
      --help)
        if [ "$kind" = "kyc" ]; then
          echo "Usage: kredit kyc [--provider=kredit]"
          echo "Issues a ${kind_uc} token for your account."
        else
          echo "Usage: kredit ${kind} <name-or-id>"
          echo "       kredit ${kind} --${id_field}=ID | --name=NAME [--sandbox-id=ID] [--provider=kredit]"
          echo "Issues a ${kind_uc} token (name must be unique)."
        fi
        return 0 ;;
      -*) die "Unknown argument: $arg" ;;
      *)
        if [[ "$arg" =~ ^[0-9a-f]{24}$ ]]; then subject_id="$arg"; else name="$arg"; fi ;;
    esac
  done

  local body="{"
  local sep=""
  if [ "$kind" != "kyc" ]; then
    [ -z "$subject_id" ] && [ -z "$name" ] && die "Missing subject: pass a name/id, --${id_field} or --name"
    [ -n "$subject_id" ] && [ -n "$name" ] && die "Pass either an id or a name, not both"
    if [ -n "$subject_id" ]; then
      body="${body}\"${id_field//-/_}\":\"${subject_id}\""; sep=","
    else
      body="${body}\"name\":\"${name}\""; sep=","
      if [ -n "$sandbox_id" ]; then body="${body}${sep}\"sandbox_id\":\"${sandbox_id}\""; fi
    fi
  fi
  if [ -n "$provider" ]; then body="${body}${sep}\"provider\":\"${provider}\""; fi
  body="${body}}"
  api_request POST "$path" "$body"
}

cmd_kya() { _identity_token kya agent-id "/agents/kya-token" "$@"; }
cmd_kyb() { _identity_token kyb org-id "/orgs/kyb-token" "$@"; }
cmd_kyc() { _identity_token kyc "" "/account/kyc-token" "$@"; }

cmd_optimize() {
  local sandbox_id="" period="1mo" apply="true"
  for arg in "$@"; do
    case "$arg" in
      --sandbox-id=*) sandbox_id="${arg#--sandbox-id=}" ;;
      --period=*) period="${arg#--period=}" ;;
      --dry-run) apply="false" ;;
      --help) echo "Usage: kredit optimize --sandbox-id=ID [--period=1mo] [--dry-run]"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done
  [ -z "$sandbox_id" ] && die "Missing --sandbox-id"
  api_request POST "/actions/optimize" "{\"sandbox_id\":\"${sandbox_id}\",\"period\":\"${period}\",\"apply\":${apply}}"
}

# kredit run <action> — one-shot full 6-stage trusted path (intent → identity →
# trust → execute → observe → optimize). Prints the returned trust_card.
cmd_run() {
  local action="" agent_id="" cost="" type="" provider="" mode="" outcome="" environment_id=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --agent) agent_id="${2:-}"; shift 2 ;;
      --agent=*) agent_id="${1#--agent=}"; shift ;;
      --cost) cost="${2:-}"; shift 2 ;;
      --cost=*) cost="${1#--cost=}"; shift ;;
      --type) type="${2:-}"; shift 2 ;;
      --type=*) type="${1#--type=}"; shift ;;
      --provider) provider="${2:-}"; shift 2 ;;
      --provider=*) provider="${1#--provider=}"; shift ;;
      --mode) mode="${2:-}"; shift 2 ;;
      --mode=*) mode="${1#--mode=}"; shift ;;
      --environment-id|--env-id) environment_id="${2:-}"; shift 2 ;;
      --environment-id=*|--env-id=*) environment_id="${1#*=}"; shift ;;
      --outcome) outcome="${2:-}"; shift 2 ;;
      --outcome=*) outcome="${1#--outcome=}"; shift ;;
      --help)
        echo "Usage: kredit run <action> --agent <agent_id> --environment-id <env> [--cost <n>] [--type <t>] [--provider <p>]"
        echo "  Runs the full 6-stage trusted path and prints the trust_card."
        echo "  TYPE: api_call, mcp_call, compute, data, tool, other"
        echo "  ENV:  the environment whose agent state the run executes against"
        return 0 ;;
      --*) die "Unknown argument: $1" ;;
      *)
        if [ -z "$action" ]; then action="$1"; else die "Unexpected argument: $1"; fi
        shift ;;
    esac
  done

  [ -z "$action" ] && die "Missing <action>"
  [ -z "$agent_id" ] && die "Missing --agent"
  [ -z "$environment_id" ] && die "Missing --environment-id (state and versions live on the environment; see 'kredit environment list')"

  local body="{\"agent_id\":\"${agent_id}\",\"action\":\"${action}\",\"environment_id\":\"${environment_id}\""
  [ -n "$cost" ] && body="${body},\"estimated_cost\":${cost}"
  [ -n "$type" ] && body="${body},\"type\":\"${type}\""
  [ -n "$provider" ] && body="${body},\"provider\":\"${provider}\""
  [ -n "$outcome" ] && body="${body},\"outcome\":\"${outcome}\""
  if [ -n "$mode" ]; then validate_mode "$mode"; body="${body},\"mode\":\"${mode}\""; fi
  body="${body}}"

  local resp
  resp=$(api_request POST "/actions/run" "$body") || return 1

  if command -v jq &>/dev/null; then
    echo "$resp" | jq -r '.trust_card.path[] | "  \(.stage) → \(.verdict) · \(.detail)"'
    echo ""
    echo "  status: $(echo "$resp" | jq -r '.status // "-"')"
  else
    echo "$resp"
  fi
}

# ── Priors (per-sandbox behavioural priors for the simulation engine) ─────────
#
# Priors describe expected agent behaviour — call frequency, per-call cost, and
# a day-of-week / hour-of-day seasonality curve — that the server's simulation
# engine samples from. Seasonality presets live server-side; `set` resolves the
# chosen preset into explicit dow/hour arrays before POSTing, since the server
# expects inlined curves.
cmd_priors() {
  local subcmd="${1:-}"; shift 2>/dev/null || true
  local sandbox_id="" mode="" environment_id="" name="" prior_id=""
  local freq_mean="" freq_var="" cost_mean="" cost_var="" preset=""
  local positionals=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --sandbox-id) sandbox_id="${2:-}"; shift 2 ;;
      --sandbox-id=*) sandbox_id="${1#--sandbox-id=}"; shift ;;
      --mode) mode="${2:-}"; shift 2 ;;
      --mode=*) mode="${1#--mode=}"; shift ;;
      --environment-id) environment_id="${2:-}"; shift 2 ;;
      --environment-id=*) environment_id="${1#--environment-id=}"; shift ;;
      --env-id) environment_id="${2:-}"; shift 2 ;;
      --env-id=*) environment_id="${1#--env-id=}"; shift ;;
      --name) name="${2:-}"; shift 2 ;;
      --name=*) name="${1#--name=}"; shift ;;
      --frequency-mean) freq_mean="${2:-}"; shift 2 ;;
      --frequency-mean=*) freq_mean="${1#--frequency-mean=}"; shift ;;
      --frequency-var) freq_var="${2:-}"; shift 2 ;;
      --frequency-var=*) freq_var="${1#--frequency-var=}"; shift ;;
      --cost-mean) cost_mean="${2:-}"; shift 2 ;;
      --cost-mean=*) cost_mean="${1#--cost-mean=}"; shift ;;
      --cost-var) cost_var="${2:-}"; shift 2 ;;
      --cost-var=*) cost_var="${1#--cost-var=}"; shift ;;
      --seasonality-preset) preset="${2:-}"; shift 2 ;;
      --seasonality-preset=*) preset="${1#--seasonality-preset=}"; shift ;;
      --help) subcmd="${subcmd:-help}"; break ;;
      --*) die "Unknown argument: $1" ;;
      *) positionals+=("$1"); shift ;;
    esac
  done

  case "$subcmd" in
    list)
      local sid; sid=$(resolve_sandbox_id "$sandbox_id")
      [ -z "$sid" ] && die "No sandbox. Pass --sandbox-id=ID or set sandbox_id=... in ~/.kredit/config"
      local query="sandbox_id=${sid}"
      if [ -n "$mode" ]; then validate_mode "$mode"; query="${query}&mode=${mode}"; fi
      [ -n "$environment_id" ] && query="${query}&environment_id=${environment_id}"
      api_request GET "/priors?${query}"
      ;;
    presets)
      api_request GET "/priors/presets"
      ;;
    set)
      [ -z "$name" ] && die "Missing --name"
      local sid; sid=$(resolve_sandbox_id "$sandbox_id")
      [ -z "$sid" ] && die "No sandbox. Pass --sandbox-id=ID or set sandbox_id=... in ~/.kredit/config"
      [ -n "$mode" ] && validate_mode "$mode"
      preset="${preset:-24x7}"

      # Resolve the seasonality preset into explicit dow/hour arrays. The server
      # stores seasonality inline, so fetch the preset and embed its curve.
      local presets seasonality
      presets=$(api_request GET "/priors/presets") || return 1
      if command -v jq &>/dev/null; then
        seasonality=$(echo "$presets" | jq -c --arg p "$preset" '.[$p] // empty')
      else
        seasonality=$(echo "$presets" | python3 -c "import sys,json; d=json.load(sys.stdin); print(json.dumps(d.get('$preset','')) if '$preset' in d else '')" 2>/dev/null)
      fi
      [ -z "$seasonality" ] && die "Unknown seasonality preset: $preset. Run 'kredit priors presets' to list them."

      freq_mean="${freq_mean:-1}"; freq_var="${freq_var:-1}"
      cost_mean="${cost_mean:-1}"; cost_var="${cost_var:-1}"

      local body="{\"name\":\"${name}\",\"frequency\":{\"mean\":${freq_mean},\"variance\":${freq_var}},\"cost\":{\"mean\":${cost_mean},\"variance\":${cost_var}},\"seasonality\":${seasonality},\"source\":\"cli\""
      [ -n "$mode" ] && body="${body},\"mode\":\"${mode}\""
      [ -n "$environment_id" ] && body="${body},\"environment_id\":\"${environment_id}\""
      body="${body}}"
      api_request POST "/priors?sandbox_id=${sid}" "$body"
      ;;
    delete)
      prior_id="${positionals[0]:-}"
      [ -z "$prior_id" ] && die "Missing <prior_id>. Usage: kredit priors delete <prior_id>"
      api_request DELETE "/priors/${prior_id}"
      ;;
    --help|help|"")
      cat <<'H'
Usage: kredit priors <list|presets|set|delete>

  kredit priors list [--sandbox-id=ID] [--mode=MODE] [--environment-id=ENV_ID]
      list behavioural priors for a sandbox (mode/environment optional filter)
  kredit priors presets
      show available seasonality presets (24x7, weekday, business-hours)
  kredit priors set --name=NAME [--frequency-mean=F] [--frequency-var=V]
                    [--cost-mean=C] [--cost-var=V]
                    [--seasonality-preset=weekday|24x7|business-hours]
                    [--sandbox-id=ID] [--mode=MODE] [--environment-id=ENV_ID]
      create a prior (seasonality defaults to 24x7; means/variances default to 1)
  kredit priors delete <prior_id>

  Sandbox resolves from --sandbox-id, then KREDIT_SANDBOX_ID, then
  sandbox_id=... in ~/.kredit/config.
  MODE: simulation, preview, production
  ENV_ID: environment id (canonical scope; --env-id is an alias)
H
      ;;
    *)
      die "Unknown priors subcommand: $subcmd"
      ;;
  esac
}

# ── Workflows (per-sandbox agent graphs the simulation engine can run) ────────
#
# A workflow is a directed graph of typed nodes (agent|llm|api|tool|payment)
# wired by edges. The server validates the graph (rejects cycles, etc.) and can
# simulate a run, emitting a per-node trust card. Graph JSON is passed inline via
# --graph or from a file via --file, and looks like:
#   {"nodes":[{"id":"n1","type":"llm","label":"plan"}],"edges":[{"from":"n1","to":"n2"}]}
# The sandbox_id + name are merged into the body before POST/PUT.
cmd_workflow() {
  local subcmd="${1:-}"; shift 2>/dev/null || true
  local sandbox_id="" mode="" environment_id="" name="" graph="" file="" seed="42"
  local positionals=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --sandbox-id) sandbox_id="${2:-}"; shift 2 ;;
      --sandbox-id=*) sandbox_id="${1#--sandbox-id=}"; shift ;;
      --mode) mode="${2:-}"; shift 2 ;;
      --mode=*) mode="${1#--mode=}"; shift ;;
      --environment-id) environment_id="${2:-}"; shift 2 ;;
      --environment-id=*) environment_id="${1#--environment-id=}"; shift ;;
      --env-id) environment_id="${2:-}"; shift 2 ;;
      --env-id=*) environment_id="${1#--env-id=}"; shift ;;
      --name) name="${2:-}"; shift 2 ;;
      --name=*) name="${1#--name=}"; shift ;;
      --graph) graph="${2:-}"; shift 2 ;;
      --graph=*) graph="${1#--graph=}"; shift ;;
      --file) file="${2:-}"; shift 2 ;;
      --file=*) file="${1#--file=}"; shift ;;
      --seed) seed="${2:-}"; shift 2 ;;
      --seed=*) seed="${1#--seed=}"; shift ;;
      --help) subcmd="${subcmd:-help}"; break ;;
      --*) die "Unknown argument: $1" ;;
      *) positionals+=("$1"); shift ;;
    esac
  done

  # Read a graph from --file if given, else use --graph. Strip the outer braces
  # so the nodes/edges can be spliced into a body that also carries sandbox_id.
  resolve_graph() {
    local g="$graph"
    if [ -n "$file" ]; then
      [ -f "$file" ] || die "Graph file not found: $file"
      g=$(cat "$file")
    fi
    [ -z "$g" ] && die "Missing graph. Pass --graph='{\"nodes\":[...],\"edges\":[...]}' or --file=path.json"
    g="${g#"${g%%[![:space:]]*}"}"; g="${g%"${g##*[![:space:]]}"}"  # trim ws
    g="${g#\{}"; g="${g%\}}"
    echo "$g"
  }

  case "$subcmd" in
    list)
      # workflows are sandbox-level definitions — no env/mode scope on listing
      local sid; sid=$(resolve_sandbox_id "$sandbox_id")
      [ -z "$sid" ] && die "No sandbox. Pass --sandbox-id=ID or set sandbox_id=... in ~/.kredit/config"
      api_request GET "/workflows?sandbox_id=${sid}"
      ;;
    create)
      [ -z "$name" ] && die "Missing --name"
      local sid; sid=$(resolve_sandbox_id "$sandbox_id")
      [ -z "$sid" ] && die "No sandbox. Pass --sandbox-id=ID or set sandbox_id=... in ~/.kredit/config"
      local gcontent; gcontent=$(resolve_graph)
      local body="{\"sandbox_id\":\"${sid}\",\"name\":\"${name}\""
      body="${body},${gcontent}}"
      api_request POST "/workflows" "$body"
      ;;
    get)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit workflow get <id>"
      api_request GET "/workflows/${id}"
      ;;
    update)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit workflow update <id> [--name=N] [--graph='<json>'|--file=path.json]"
      local parts=""
      [ -n "$name" ] && parts="\"name\":\"${name}\""
      if [ -n "$graph" ] || [ -n "$file" ]; then
        local gcontent; gcontent=$(resolve_graph)
        [ -n "$parts" ] && parts="${parts},"
        parts="${parts}${gcontent}"
      fi
      [ -z "$parts" ] && die "Nothing to update. Pass --name and/or --graph/--file"
      api_request PUT "/workflows/${id}" "{${parts}}"
      ;;
    delete)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit workflow delete <id>"
      api_request DELETE "/workflows/${id}"
      ;;
    run)
      # the environment is chosen at execution time — the definition is env-free
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit workflow run <id> [--environment-id=ENV] [--seed=N]"
      local q="seed=${seed}"
      [ -n "$environment_id" ] && q="${q}&environment_id=${environment_id}"
      local resp
      resp=$(api_request POST "/workflows/${id}/simulate?${q}") || return 1
      if command -v jq &>/dev/null; then
        echo "  workflow: $(echo "$resp" | jq -r '.workflow_id // "-"')  mode: $(echo "$resp" | jq -r '.mode // "-"')"
        echo "  nodes: $(echo "$resp" | jq -r '.node_count // 0')  blocked: $(echo "$resp" | jq -r '.blocked_count // 0')  total_cost: \$$(echo "$resp" | jq -r '.total_cost // 0')"
        echo ""
        echo "$resp" | jq -r '.node_runs[]? | "  \(.node_id)  \(.type)  \(.integration // "-") -> \(.status) $\(.cost // 0)"'
      else
        echo "$resp"
      fi
      ;;
    execute)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit workflow execute <id> --environment-id=ENV [--seed=N]"
      [ -z "$environment_id" ] && die "Missing --environment-id (execution runs against one environment's state)"
      local resp
      resp=$(api_request POST "/workflows/${id}/execute?seed=${seed}&environment_id=${environment_id}") || return 1
      if command -v jq &>/dev/null; then
        echo "  run: $(echo "$resp" | jq -r '.id // "-"')  workflow: $(echo "$resp" | jq -r '.workflow_id // "-"')  mode: $(echo "$resp" | jq -r '.mode // "-"')  status: $(echo "$resp" | jq -r '.status // "-"')"
        echo "  nodes: $(echo "$resp" | jq -r '.node_count // 0')  blocked: $(echo "$resp" | jq -r '.blocked_count // 0')  total_cost: \$$(echo "$resp" | jq -r '.total_cost // 0')"
        echo ""
        echo "$resp" | jq -r '.node_runs[]? | "  \(.node_id)  \(.type)  \(.integration // "-") -> \(.status) $\(.cost // 0) tx=\(.transaction_id // "-")"'
      else
        echo "$resp"
      fi
      ;;
    runs)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit workflow runs <id>"
      local resp
      resp=$(api_request GET "/workflows/${id}/runs") || return 1
      if command -v jq &>/dev/null; then
        echo "$resp" | jq -r '.[]? | "  \(.id)  \(.mode)  \(.status)  nodes=\(.node_count // 0) blocked=\(.blocked_count // 0) total_cost=$\(.total_cost // 0)  \(.created_at // "-")"'
      else
        echo "$resp"
      fi
      ;;
    run-get)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <run_id>. Usage: kredit workflow run-get <run_id>"
      api_request GET "/workflows/runs/${id}"
      ;;
    --help|help|"")
      cat <<'H'
Usage: kredit workflow <list|create|get|update|delete|run|execute|runs|run-get>

  kredit workflow list [--sandbox-id=ID] [--mode=MODE] [--environment-id=ENV_ID]
      list workflows for a sandbox (mode/environment optional filter)
  kredit workflow create --name=NAME (--graph='<json>' | --file=path.json)
                    [--sandbox-id=ID] [--mode=MODE] [--environment-id=ENV_ID]
      create a workflow; <json> is {"nodes":[...],"edges":[...]}
  kredit workflow get <id>
  kredit workflow update <id> [--name=NAME] [--graph='<json>' | --file=path.json]
  kredit workflow delete <id>
  kredit workflow run <id> [--seed=N]
      simulate the workflow; prints node_count, blocked, total_cost, per-node runs
  kredit workflow execute <id> [--seed=N]
      execute the workflow for real (settled per mode); prints the run record
      with node_count, blocked, total_cost, and per-node runs (with tx ids)
  kredit workflow runs <id>
      list past execution runs for a workflow
  kredit workflow run-get <run_id>
      get a single execution run record by run id

  Node types: agent | llm | api | tool | payment
  Sandbox resolves from --sandbox-id, then KREDIT_SANDBOX_ID, then
  sandbox_id=... in ~/.kredit/config.
  MODE: simulation, preview, production
  ENV_ID: environment id (canonical scope; --env-id is an alias)
H
      ;;
    *)
      die "Unknown workflow subcommand: $subcmd"
      ;;
  esac
}

# ── Environments (the scope inside a sandbox: modes + per-simulation snapshots) ─
#
# A sandbox contains many environments, each scoped by a mode (simulation |
# preview | production). The 3 modes are the standard environments (exactly one
# production env per sandbox); each simulation run is its own simulation-mode
# environment (with simulation_id) nested inside its parent env via
# parent_environment_id. Orgs/agents/rules/priors/workflows belong to an
# environment. Standard (mode) envs cannot be deleted.
cmd_environment() {
  local subcmd="${1:-}"; shift 2>/dev/null || true
  local sandbox_id="" mode="" name="" simulation_id=""
  local positionals=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --sandbox-id) sandbox_id="${2:-}"; shift 2 ;;
      --sandbox-id=*) sandbox_id="${1#--sandbox-id=}"; shift ;;
      --mode) mode="${2:-}"; shift 2 ;;
      --mode=*) mode="${1#--mode=}"; shift ;;
      --name) name="${2:-}"; shift 2 ;;
      --name=*) name="${1#--name=}"; shift ;;
      --simulation-id) simulation_id="${2:-}"; shift 2 ;;
      --simulation-id=*) simulation_id="${1#--simulation-id=}"; shift ;;
      --help) subcmd="${subcmd:-help}"; break ;;
      --*) die "Unknown argument: $1" ;;
      *) positionals+=("$1"); shift ;;
    esac
  done

  case "$subcmd" in
    list)
      local sid; sid=$(resolve_sandbox_id "$sandbox_id")
      [ -z "$sid" ] && die "No sandbox. Pass --sandbox-id=ID or set sandbox_id=... in ~/.kredit/config"
      local resp
      resp=$(api_request GET "/environments?sandbox_id=${sid}") || return 1
      if command -v jq &>/dev/null; then
        echo "$resp" | jq -r '.[] | "  \(if .active then "*" else " " end) \(.mode)\t\(.name)\(if .parent_environment_id then "  (parent: \(.parent_environment_id))" else "" end)"'
      else
        echo "$resp"
      fi
      ;;
    create)
      [ -z "$mode" ] && die "Missing --mode (simulation|preview|production)"
      local sid; sid=$(resolve_sandbox_id "$sandbox_id")
      [ -z "$sid" ] && die "No sandbox. Pass --sandbox-id=ID or set sandbox_id=... in ~/.kredit/config"
      local body="{\"sandbox_id\":\"${sid}\",\"mode\":\"${mode}\""
      [ -n "$name" ] && body="${body},\"name\":\"${name}\""
      [ -n "$simulation_id" ] && body="${body},\"simulation_id\":\"${simulation_id}\""
      body="${body}}"
      api_request POST "/environments" "$body"
      ;;
    get)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit environment get <id>"
      api_request GET "/environments/${id}"
      ;;
    delete)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit environment delete <id>"
      api_request DELETE "/environments/${id}"
      ;;
    --help|help|"")
      cat <<'H'
Usage: kredit environment <list|create|get|delete>   (alias: env)

  kredit environment list [--sandbox-id=ID]
      list a sandbox's environments (mode, name, active *); simulation run
      envs (mode simulation with a parent) also show their parent environment
  kredit environment create --mode=MODE [--name=NAME] [--sandbox-id=ID] [--simulation-id=ID]
      MODE: simulation | preview | production
  kredit environment get <id>
  kredit environment delete <id>
      (standard mode environments cannot be deleted)

  Sandbox resolves from --sandbox-id, then KREDIT_SANDBOX_ID, then
  sandbox_id=... in ~/.kredit/config.
H
      ;;
    *)
      die "Unknown environment subcommand: $subcmd"
      ;;
  esac
}

# ── Chats (persisted Kredit-agent conversations) ──────────────────────────────
#
# A chat is a conversation with the Kredit orchestrator agent, bound to a sandbox
# (and optionally a mode/simulation). These verbs manage the chat container and
# its message history; the turn-by-turn agent send loop lives server-side.
cmd_chat() {
  local subcmd="${1:-}"; shift 2>/dev/null || true
  local sandbox_id=""
  local positionals=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --sandbox-id) sandbox_id="${2:-}"; shift 2 ;;
      --sandbox-id=*) sandbox_id="${1#--sandbox-id=}"; shift ;;
      --help) subcmd="${subcmd:-help}"; break ;;
      --*) die "Unknown argument: $1" ;;
      *) positionals+=("$1"); shift ;;
    esac
  done

  case "$subcmd" in
    list)
      local sid; sid=$(resolve_sandbox_id "$sandbox_id")
      [ -z "$sid" ] && die "No sandbox. Pass --sandbox-id=ID or set sandbox_id=... in ~/.kredit/config"
      local resp
      resp=$(api_request GET "/chats?sandbox_id=${sid}") || return 1
      if command -v jq &>/dev/null; then
        echo "$resp" | jq -r '.[] | "  \(.id)\t\(.title)"'
      else
        echo "$resp"
      fi
      ;;
    get)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit chat get <id>"
      local resp
      resp=$(api_request GET "/chats/${id}") || return 1
      if command -v jq &>/dev/null; then
        echo "  $(echo "$resp" | jq -r '.title // "-"')"
        echo ""
        echo "$resp" | jq -r '.messages[]? | "  [\(.role)] \(.content)"'
      else
        echo "$resp"
      fi
      ;;
    delete)
      local id="${positionals[0]:-}"
      [ -z "$id" ] && die "Missing <id>. Usage: kredit chat delete <id>"
      api_request DELETE "/chats/${id}"
      ;;
    --help|help|"")
      cat <<'H'
Usage: kredit chat <list|get|delete>

  kredit chat list [--sandbox-id=ID]
      list persisted chats for a sandbox
  kredit chat get <id>
      print a chat's title and each message (role + content)
  kredit chat delete <id>

  Sandbox resolves from --sandbox-id, then KREDIT_SANDBOX_ID, then
  sandbox_id=... in ~/.kredit/config.
H
      ;;
    *)
      die "Unknown chat subcommand: $subcmd"
      ;;
  esac
}

show_help() {
  cat <<'HELP'
kredit — CLI for the Kredit financial risk management API

Usage:
  kredit <command> [options]

Commands:
  login       Authenticate and create an API key
  logout      Remove saved API key
  init        kredit init sandbox simulation <name> — create a sandbox
  sandbox     Manage sandboxes (create/copy/promote/versions/switch)
  simulation  Live or predictive simulation on a sandbox (live | predictive)
  action      Dry-run the trust layer (action intent)
  execute     Execute a payment/api/tool action (env-gated)
  verify      Run identity verification (kya/kyb/kyc)
  kya         Issue a KYA token for an agent (by name or id) [--provider]
  kyb         Issue a KYB token for an org (by name or id) [--provider]
  kyc         Issue a KYC token for your account [--provider]
  optimize    Optimize a sandbox's guardrails from a simulation
  priors      Manage a sandbox's behavioural priors (list, presets, set, delete)
  workflow    Manage sandbox workflows (list, create, get, update, delete, run, execute, runs, run-get)
  environment Manage sandbox environments / modes (list, create, get, delete; alias: env)
  chat        Manage persisted agent chats (list, get, delete)
  rules       Manage agent rules (list, add, remove)
  check       Run a risk check before executing an action
  run         Run the full 6-stage trusted path in one shot (prints trust_card)
  report      Report the outcome of an action
  agents      Manage agents (list, create)
  orgs        Manage organizations (list, create)
  score       Get/recompute trust score (score trust)
  wallet      Get wallet info for an agent

Modes:
  Sandboxes carry a mode per fleet/rule scope. Fresh sandboxes land in
  `simulation`. Promote order: simulation → preview → production.
  Agent STATE (wallet, counters, score) and versions live on an ENVIRONMENT, so
  `check`, `run`, and `workflow execute` require --environment-id (alias
  --env-id). orgs/agents/priors (list, create/set) accept an optional
  --environment-id; --mode scopes by mode name when no environment id is given.
  Workflows are sandbox-level definitions — the environment is chosen at
  execution time. `kredit sandbox deploy` copies one mode's fleet/rules into
  another.

Options:
  --help      Show help for a command
  --version   Print version

Examples:
  kredit check --agent-id=agt_8f3k2m --action=serp_api.search --estimated-cost=1 --environment-id=env_123
  kredit run openai.chat --agent agt_8f3k2m --environment-id env_123 --cost 1 --type api_call
  kredit report --transaction-id=txn_abc --outcome=success --actual-cost=1
  kredit agents list --org-id=org_123 --mode=simulation
  kredit agents create --org-name=research-team --name=bot-01 --mode=preview
  kredit rules add --agent-id=ID --name="OpenAI" --match="openai.*" --max-cost-per-txn=5 --daily-spend-limit=100 --hourly-rate-limit=50 --mode=production
  kredit orgs list --mode=simulation
  kredit orgs create --name=research-team
  kredit score --agent-id=agt_8f3k2m
  kredit wallet --agent-id=agt_8f3k2m
  kredit kya checkout-bot
  kredit kya --agent-id=agt_8f3k2m --provider=skyfire
  kredit kyb research-team
  kredit kyb --org-id=org_123 --provider=experian
  kredit kyc --provider=plaid
  kredit sandbox deploy simulation preview --include=orgs,agents,rules --sandbox-id=sbx_123
  kredit priors presets
  kredit priors set --name=web-search --frequency-mean=6 --cost-mean=3 --seasonality-preset=weekday --sandbox-id=sbx_123
  kredit priors list --sandbox-id=sbx_123
  kredit workflow create --name=demo --graph='{"nodes":[{"id":"n1","type":"llm"}],"edges":[]}' --sandbox-id=sbx_123
  kredit workflow run wf_123 --seed=5
  kredit workflow execute wf_123 --environment-id=env_123
  kredit environment list --sandbox-id=sbx_123
  kredit environment create --mode=simulation --name=exp-a --sandbox-id=sbx_123
  kredit chat list --sandbox-id=sbx_123
  kredit chat get cht_123

Environment:
  KREDIT_API_KEY   API key (or set in ~/.kredit/config as api_key=...)
  KREDIT_API_URL   Base URL (default: https://api.kredit.sh)
HELP
}

# ── Main dispatch ────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-}"
  shift 2>/dev/null || true

  case "$cmd" in
    login)    cmd_login "$@" ;;
    logout)   cmd_logout "$@" ;;
    init)     cmd_init "$@" ;;
    simulation) cmd_sim "$@" ;;
    demo)     cmd_simulation "$@" ;;  # legacy alias for `kredit simulation live`
    check)    cmd_check "$@" ;;
    run)      cmd_run "$@" ;;
    report)   cmd_report "$@" ;;
    agents)   cmd_agents "$@" ;;
    rules)    cmd_rules "$@" ;;
    orgs)     cmd_orgs "$@" ;;
    sandbox)  cmd_sandbox "$@" ;;
    action)   cmd_action "$@" ;;
    execute)  cmd_execute "$@" ;;
    verify)   cmd_verify "$@" ;;
    kya)      cmd_kya "$@" ;;
    kyb)      cmd_kyb "$@" ;;
    kyc)      cmd_kyc "$@" ;;
    optimize) cmd_optimize "$@" ;;
    priors)   cmd_priors "$@" ;;
    workflow) cmd_workflow "$@" ;;
    environment|env) cmd_environment "$@" ;;
    chat)     cmd_chat "$@" ;;
    score)    cmd_score "$@" ;;
    wallet)   cmd_wallet "$@" ;;
    --help|-h|help) show_help ;;
    --version|-v) echo "kredit $VERSION" ;;
    "")
      show_help
      exit 1
      ;;
    *)
      die "Unknown command: $cmd. Run 'kredit --help' for usage."
      ;;
  esac
}

main "$@"
