#!/usr/bin/env bash
#
# kredit — CLI for the Kredit financial risk management API
#
# Usage:
#   kredit check   --agent-id=ID --action=ACTION --estimated-cost=COST [--type=TYPE]
#   kredit report  --transaction-id=ID --outcome=OUTCOME [--actual-cost=COST]
#   kredit agents  list [--org-id=ORG_ID]
#   kredit agents  create --org-name=ORG_NAME --name=AGENT_NAME
#   kredit orgs    create --name=ORG_NAME
#   kredit orgs    list
#   kredit score   --agent-id=ID
#   kredit wallet  --agent-id=ID
#
# Environment:
#   KREDIT_API_KEY  — API key (or set in ~/.kredit/config as api_key=...)
#   KREDIT_API_URL  — Base URL (default: https://api.kredit.sh)

set -euo pipefail

VERSION="0.3.2"

# ── Config resolution ────────────────────────────────────────────────────────

resolve_api_key() {
  if [ -n "${KREDIT_API_KEY:-}" ]; then
    echo "$KREDIT_API_KEY"
    return
  fi

  local config_file="${HOME:-$(eval echo ~)}/.kredit/config"
  if [ -f "$config_file" ]; then
    local key
    key=$(grep -E '^(api_key|KREDIT_API_KEY)=' "$config_file" 2>/dev/null | head -1 | cut -d'=' -f2- | tr -d ' ')
    if [ -n "$key" ]; then
      echo "$key"
      return
    fi
  fi

  echo ""
}

API_KEY=$(resolve_api_key)
BASE_URL="${KREDIT_API_URL:-https://api.kredit.sh}"
BASE_URL="${BASE_URL%/}"

# ── Helpers ──────────────────────────────────────────────────────────────────

die() {
  echo "error: $1" >&2
  exit 1
}

require_api_key() {
  if [ -z "$API_KEY" ]; then
    die "No API key. Set KREDIT_API_KEY or add api_key=... to ~/.kredit/config"
  fi
}

# Format JSON output — use jq if available, otherwise cat as-is
format_json() {
  if command -v jq &>/dev/null; then
    jq .
  else
    cat
  fi
}

# HTTP request with 5s timeout and 2 retries with backoff
api_request() {
  local method="$1"
  local path="$2"
  shift 2
  local data="${1:-}"

  require_api_key

  local url="${BASE_URL}${path}"
  local attempt=0
  local max_retries=2
  local response
  local http_code

  while [ $attempt -le $max_retries ]; do
    local curl_args=(
      --silent
      --show-error
      --max-time 5
      --write-out "\n%{http_code}"
      -H "Authorization: Bearer ${API_KEY}"
      -H "Content-Type: application/json"
      -H "User-Agent: kredit-cli/${VERSION}"
    )

    curl_args+=(-X "$method")
    if [ -n "$data" ]; then
      curl_args+=(-d "$data")
    fi

    curl_args+=("$url")

    local raw
    raw=$(curl "${curl_args[@]}" 2>&1) || true

    # Last line is the HTTP status code
    http_code=$(echo "$raw" | tail -1)
    response=$(echo "$raw" | sed '$d')

    # Success
    if [[ "$http_code" =~ ^2[0-9][0-9]$ ]]; then
      echo "$response" | format_json
      return 0
    fi

    # Client errors — don't retry
    if [[ "$http_code" =~ ^4[0-9][0-9]$ ]]; then
      echo "error: HTTP $http_code" >&2
      echo "$response" | format_json >&2
      return 1
    fi

    # Server errors or connection failures — retry with backoff
    attempt=$((attempt + 1))
    if [ $attempt -le $max_retries ]; then
      local delay
      delay=$(echo "0.5 * (2 ^ ($attempt - 1))" | bc -l 2>/dev/null || echo "1")
      sleep "$delay"
    fi
  done

  echo "error: Request failed after $((max_retries + 1)) attempts (last HTTP $http_code)" >&2
  echo "$response" | format_json >&2
  return 1
}

DASHBOARD_URL="${KREDIT_DASHBOARD_URL:-https://kredit.sh}"

# ── Login ───────────────────────────────────────────────────────────────────

cmd_login() {
  echo "Logging in to Kredit..."

  # Find a free port
  local port
  port=$(python3 -c "import socket; s=socket.socket(); s.bind(('',0)); print(s.getsockname()[1]); s.close()" 2>/dev/null) || die "Python 3 required for login"

  local token=""
  local login_url="${DASHBOARD_URL}/auth/cli-callback?port=${port}"

  # Start a tiny HTTP server that waits for the callback
  python3 -c "
import http.server, urllib.parse, sys, threading

class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        params = urllib.parse.parse_qs(parsed.query)
        token = params.get('token', [''])[0]
        if token:
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(b'<html><body style=\"font-family:sans-serif;text-align:center;margin-top:80px\"><h2>Logged in to Kredit</h2><p>You can close this window and return to your terminal.</p></body></html>')
            with open('/tmp/.kredit_cli_token', 'w') as f:
                f.write(token)
            threading.Thread(target=self.server.shutdown).start()
        else:
            self.send_response(400)
            self.end_headers()
            self.wfile.write(b'Missing token')
    def log_message(self, *args): pass

server = http.server.HTTPServer(('127.0.0.1', ${port}), Handler)
server.serve_forever()
" &
  local server_pid=$!

  # Open browser
  echo "Opening browser for authentication..."
  if command -v open &>/dev/null; then
    open "$login_url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$login_url"
  else
    echo "Open this URL in your browser:"
    echo "  $login_url"
  fi

  echo "Waiting for authentication..."

  # Wait for the server to finish (max 120 seconds)
  local waited=0
  while kill -0 $server_pid 2>/dev/null; do
    sleep 1
    waited=$((waited + 1))
    if [ $waited -ge 120 ]; then
      kill $server_pid 2>/dev/null
      rm -f /tmp/.kredit_cli_token
      die "Login timed out after 120 seconds"
    fi
  done

  # Read the token
  if [ ! -f /tmp/.kredit_cli_token ]; then
    die "Login failed — no token received"
  fi

  token=$(cat /tmp/.kredit_cli_token)
  rm -f /tmp/.kredit_cli_token

  if [ -z "$token" ]; then
    die "Login failed — empty token"
  fi

  echo "Authenticated. Creating API key..."

  # Create an API key using the JWT
  local response
  response=$(curl --silent --show-error --max-time 10 \
    -X POST \
    -H "Authorization: Bearer ${token}" \
    -H "Content-Type: application/json" \
    "${BASE_URL}/auth/keys" 2>&1) || die "Failed to create API key"

  local api_key
  if command -v jq &>/dev/null; then
    api_key=$(echo "$response" | jq -r '.key // empty')
  else
    api_key=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('key',''))" 2>/dev/null)
  fi

  if [ -z "$api_key" ]; then
    echo "error: Failed to create API key" >&2
    echo "$response" | format_json >&2
    exit 1
  fi

  # Save to ~/.kredit/config
  local home="${HOME:-$(eval echo ~)}"
  mkdir -p "$home/.kredit"
  touch "$home/.kredit/config"
  echo "api_key=${api_key}" > "$home/.kredit/config"
  chmod 600 "$home/.kredit/config"

  echo ""
  echo "API key created and saved to ~/.kredit/config"
  echo "Key: ${api_key}"
  echo ""
  echo "You're ready to go. Try: kredit orgs create --name=my-team"
}

cmd_demo() {
  require_api_key

  local home="${HOME:-$(eval echo ~)}"
  mkdir -p "$home/.kredit"
  local LOG_FILE="$home/.kredit/sim-$(date +%Y%m%d-%H%M%S).log"
  _cmd_demo_inner 2>&1 | tee "$LOG_FILE"
}

_cmd_demo_inner() {
  # Relax strict mode inside the demo — individual curl/jq hiccups must
  # not kill the simulation loop. We still log them in the output.
  set +e
  set +u
  set +o pipefail

  echo ""
  echo "  ╔═══════════════════════════════════════════════════════╗"
  echo "  ║         Kredit 60-Second Demo Simulation              ║"
  echo "  ║         10 agents · many transactions · per-second    ║"
  echo "  ╚═══════════════════════════════════════════════════════╝"
  echo ""
  echo "  Log file: $LOG_FILE"
  echo "  Dashboard: https://kredit.sh/dashboard/spend"
  echo ""

  # ── Phase 1: Create unique org ───────────────────────────────────────────
  local org_name="kredit-demo-$(date +%Y%m%d-%H%M%S)"
  echo "[1/3] Creating org: $org_name"
  local org_response org_id
  org_response=$(curl -s -X POST "${BASE_URL}/orgs" \
    -H "Authorization: Bearer ${API_KEY}" \
    -H "Content-Type: application/json" \
    -d "{\"name\":\"$org_name\"}" 2>/dev/null)
  org_id=$(echo "$org_response" | jq -r '.id // empty' 2>/dev/null)
  [ -z "$org_id" ] && die "Failed to create org: $org_response"
  echo "      org_id: $org_id"
  echo ""

  # ── Phase 2: Create 10 agents with diverse rule profiles ─────────────────
  echo "[2/3] Creating 10 agents..."
  echo ""
  local agents=() names=() init_scores=()

  _mk_agent() {
    local name="$1" priority="$2" balance="$3" budget="$4" max_txn="$5" daily="$6" rules="$7"
    local wallet="{\"balance\":$balance,\"budget\":$budget,\"max_per_txn\":$max_txn,\"daily_spend_limit\":$daily}"
    local body="{\"org_name\":\"$org_name\",\"name\":\"$name\",\"priority\":\"$priority\",\"wallet\":$wallet,\"rules\":$rules}"
    local resp id
    resp=$(curl -s -X POST "${BASE_URL}/agents" \
      -H "Authorization: Bearer ${API_KEY}" \
      -H "Content-Type: application/json" \
      -d "$body" 2>/dev/null)
    id=$(echo "$resp" | jq -r '.id // empty' 2>/dev/null)
    if [ -n "$id" ]; then
      agents+=("$id")
      names+=("$name")
      local score
      score=$(echo "$resp" | jq -r '.credit.score // 600')
      init_scores+=("$score")
      printf "      ✓ %-18s priority=%-8s balance=\$%-5d budget=\$%-5d max=\$%-4d daily=\$%-5d  id=%s\n" \
        "$name" "$priority" "$balance" "$budget" "$max_txn" "$daily" "$id"
      echo "$resp" | jq -r '.rules[] | "          rule: \(.name) [match=\(.match)]" + (if .max_cost_per_txn > 0 then "  max_cost=$\(.max_cost_per_txn)" else "" end) + (if .daily_spend_limit > 0 then "  daily=$\(.daily_spend_limit)" else "" end) + (if .hourly_rate_limit > 0 then "  rate=\(.hourly_rate_limit)/hr" else "" end)'
    else
      echo "      ✗ failed: $name — $resp"
    fi
  }

  local R_OPENAI='[{"name":"OpenAI cap","match":"openai.*","max_cost_per_txn":5,"daily_spend_limit":100,"hourly_rate_limit":120},{"name":"Default","match":"*","max_cost_per_txn":10,"daily_spend_limit":200}]'
  local R_CLAUDE='[{"name":"Claude cap","match":"anthropic.*","max_cost_per_txn":3,"daily_spend_limit":80,"hourly_rate_limit":120},{"name":"Default","match":"*","max_cost_per_txn":2}]'
  local R_CODE='[{"name":"Code APIs","match":"openai.*","max_cost_per_txn":8,"daily_spend_limit":150,"hourly_rate_limit":200},{"name":"GitHub","match":"github.*","max_cost_per_txn":0.5,"hourly_rate_limit":200}]'
  local R_RESEARCH='[{"name":"Search","match":"serp.*","max_cost_per_txn":2,"hourly_rate_limit":80},{"name":"Scrape","match":"browserless.*","max_cost_per_txn":5,"hourly_rate_limit":60},{"name":"Default","match":"*","max_cost_per_txn":5}]'
  local R_TRAVEL='[{"name":"Flight cap","match":"flight.*","max_cost_per_txn":800,"daily_spend_limit":2000,"hourly_rate_limit":10},{"name":"Hotel cap","match":"hotel.*","max_cost_per_txn":400,"daily_spend_limit":1000,"hourly_rate_limit":10}]'
  local R_PROC='[{"name":"Vendor cap","match":"vendor.*","max_cost_per_txn":1000,"daily_spend_limit":5000,"hourly_rate_limit":20},{"name":"Equip cap","match":"equipment.*","max_cost_per_txn":500,"daily_spend_limit":2000}]'
  local R_CLOUD='[{"name":"AWS cap","match":"aws.*","max_cost_per_txn":50,"daily_spend_limit":500,"hourly_rate_limit":120}]'
  local R_COMMS='[{"name":"Slack","match":"slack.*","max_cost_per_txn":0.5,"hourly_rate_limit":120},{"name":"Email","match":"sendgrid.*","max_cost_per_txn":1,"hourly_rate_limit":60},{"name":"SMS","match":"twilio.*","max_cost_per_txn":0.5,"hourly_rate_limit":30}]'
  local R_DATA='[{"name":"Postgres","match":"postgres.*","max_cost_per_txn":0.5,"hourly_rate_limit":300},{"name":"Redis","match":"redis.*","max_cost_per_txn":0.01,"hourly_rate_limit":600}]'
  local R_ROGUE='[{"name":"Tight cap","match":"*","max_cost_per_txn":15,"daily_spend_limit":100}]'

  _mk_agent "gpt-writer"      "critical" 500  500  5    100  "$R_OPENAI"
  _mk_agent "claude-agent"    "high"     400  400  3    80   "$R_CLAUDE"
  _mk_agent "code-assistant"  "high"     250  250  8    150  "$R_CODE"
  _mk_agent "research-bot"    "normal"   300  300  5    100  "$R_RESEARCH"
  _mk_agent "travel-agent"    "high"     5000 5000 800  2000 "$R_TRAVEL"
  _mk_agent "procurement-bot" "normal"   2000 2000 1000 5000 "$R_PROC"
  _mk_agent "cloud-deployer"  "high"     400  400  50   500  "$R_CLOUD"
  _mk_agent "comms-bot"       "normal"   100  100  1    50   "$R_COMMS"
  _mk_agent "data-agent"      "normal"   150  150  1    50   "$R_DATA"
  _mk_agent "rogue-spender"   "normal"   300  300  15   100  "$R_ROGUE"

  local total=${#agents[@]}
  echo ""
  echo "      Created $total agents"
  echo ""

  # ── Phase 3: Run 60-second transaction burst ─────────────────────────────
  echo "[3/3] Running 60s of transactions..."
  echo ""
  printf "  %-8s %-18s %-22s %10s   %-8s  %8s  %8s   %-6s  %s\n" "T+ms" "AGENT" "ACTION" "COST" "STATUS" "DEC(ms)" "NET(ms)" "RISK" "DETAIL"
  echo "  ─────────────────────────────────────────────────────────────────────────────────────────────────────"

  # 25 distinct APIs across categories (>= 20 as requested)
  local API_ACTIONS=("openai.chat" "openai.embeddings" "openai.image" "openai.tts" "anthropic.messages" "serp.search" "browserless.scrape" "github.api" "github.gist" "datadog.metric")
  local SPEND_ACTIONS=("flight.booking" "hotel.booking" "vendor.payout" "equipment.purchase" "software.license" "catering.order")
  local INFRA_ACTIONS=("aws.ec2.run" "aws.s3.put" "aws.lambda.invoke" "aws.rds.query")
  local COMMS_ACTIONS=("slack.post" "sendgrid.email" "twilio.sms")
  local DATA_ACTIONS=("postgres.query" "redis.set" "redis.get")
  local OUTCOMES=("success" "success" "success" "success" "failure" "partial")

  local start_s end_s
  start_s=$(date +%s)
  end_s=$((start_s + 60))
  local tx=0 allowed=0 blocked=0 flagged=0 total_latency=0

  while [ "$(date +%s)" -lt "$end_s" ]; do
    local idx=$((RANDOM % total))
    local aid="${agents[$idx]}" aname="${names[$idx]}"

    local action cost
    case "$aname" in
      travel-agent)    action="${SPEND_ACTIONS[$((RANDOM % ${#SPEND_ACTIONS[@]}))]}";  cost=$(awk "BEGIN{printf \"%.2f\",(($RANDOM%50000)+1000)/100.0}");;
      procurement-bot) action="${SPEND_ACTIONS[$((RANDOM % ${#SPEND_ACTIONS[@]}))]}";  cost=$(awk "BEGIN{printf \"%.2f\",(($RANDOM%30000)+500)/100.0}");;
      cloud-deployer)  action="${INFRA_ACTIONS[$((RANDOM % ${#INFRA_ACTIONS[@]}))]}";  cost=$(awk "BEGIN{printf \"%.2f\",(($RANDOM%6000)+100)/100.0}");;
      comms-bot)       action="${COMMS_ACTIONS[$((RANDOM % ${#COMMS_ACTIONS[@]}))]}";  cost=$(awk "BEGIN{printf \"%.2f\",(($RANDOM%100)+1)/100.0}");;
      data-agent)      action="${DATA_ACTIONS[$((RANDOM % ${#DATA_ACTIONS[@]}))]}";    cost=$(awk "BEGIN{printf \"%.2f\",(($RANDOM%50)+1)/100.0}");;
      rogue-spender)   action="${SPEND_ACTIONS[$((RANDOM % ${#SPEND_ACTIONS[@]}))]}";  cost=$(awk "BEGIN{printf \"%.2f\",(($RANDOM%9000)+500)/100.0}");;
      claude-agent)    action="anthropic.messages";                                    cost=$(awk "BEGIN{printf \"%.2f\",(($RANDOM%500)+10)/100.0}");;
      *)               action="${API_ACTIONS[$((RANDOM % ${#API_ACTIONS[@]}))]}";      cost=$(awk "BEGIN{printf \"%.2f\",(($RANDOM%1000)+10)/100.0}");;
    esac

    # Single curl call gives both response body AND request latency — no python wrappers
    local resp_with_time result latency_sec latency status txn_id risk reason
    resp_with_time=$(curl -s -w "\n%{time_total}" -X POST "${BASE_URL}/check" \
      -H "Authorization: Bearer ${API_KEY}" \
      -H "Content-Type: application/json" \
      -d "{\"agent_id\":\"$aid\",\"action\":\"$action\",\"estimated_cost\":$cost}" 2>/dev/null)
    latency_sec=$(printf "%s" "$resp_with_time" | tail -n 1)
    result=$(printf "%s" "$resp_with_time" | sed '$d')
    [ -z "$latency_sec" ] && latency_sec="0"
    latency=$(awk -v l="$latency_sec" 'BEGIN{printf "%d", l*1000}')
    [ -z "$latency" ] && latency=0
    total_latency=$((total_latency + latency))

    status=$(printf "%s" "$result" | jq -r '.status // "error"' 2>/dev/null)
    [ -z "$status" ] && status="error"
    txn_id=$(printf "%s" "$result" | jq -r '.transaction_id // empty' 2>/dev/null)
    risk=$(printf "%s" "$result"   | jq -r '.risk_level // "-"' 2>/dev/null)
    [ -z "$risk" ] && risk="-"
    reason=$(printf "%s" "$result" | jq -r '.block_reason // ""' 2>/dev/null)

    # Server-side decision latency from response body (what Kredit's risk engine reports)
    local server_lat
    server_lat=$(printf "%s" "$result" | jq -r '.latency_ms // 0' 2>/dev/null)
    [ -z "$server_lat" ] && server_lat=0
    local server_lat_int
    server_lat_int=$(awk -v l="$server_lat" 'BEGIN{printf "%d", l}')

    tx=$((tx + 1))
    # Cumulative latency gives ms-precision T+ offset without needing high-res clocks
    local t_offset=$total_latency

    case "$status" in
      allowed)
        allowed=$((allowed + 1))
        local outcome="${OUTCOMES[$((RANDOM % ${#OUTCOMES[@]}))]}"
        local ac=$cost
        [ "$outcome" = "failure" ] && ac=$(awk "BEGIN{printf \"%.2f\",$cost*0.3}")
        [ -n "$txn_id" ] && curl -s -X POST "${BASE_URL}/report" \
          -H "Authorization: Bearer ${API_KEY}" \
          -H "Content-Type: application/json" \
          -d "{\"transaction_id\":\"$txn_id\",\"outcome\":\"$outcome\",\"actual_cost\":$ac}" > /dev/null 2>&1 &
        ;;
      blocked) blocked=$((blocked + 1)) ;;
      flagged) flagged=$((flagged + 1)) ;;
    esac

    local detail="$reason"
    printf "  +%-7d %-18s %-22s \$%9s   %-8s  %8d  %8d   %-6s  %s\n" \
      "$t_offset" "$aname" "$action" "$cost" "$status" "$server_lat_int" "$latency" "$risk" "$detail"
  done
  wait

  local elapsed_s avg_lat throughput
  elapsed_s=$(( $(date +%s) - start_s ))
  [ "$elapsed_s" -lt 1 ] && elapsed_s=1
  [ "$tx" -lt 1 ] && tx=1
  avg_lat=$((total_latency / tx))
  throughput=$(awk "BEGIN{printf \"%.1f\",$tx/$elapsed_s}")

  echo ""
  echo "  ═══════════════════════════════════════════════════════"
  echo "  Simulation summary"
  echo "  ═══════════════════════════════════════════════════════"
  echo ""
  printf "  %-14s %s\n"    "Org:"        "$org_name"
  printf "  %-14s %s\n"    "Org ID:"     "$org_id"
  printf "  %-14s %s\n"    "Agents:"     "$total"
  printf "  %-14s %ss\n"   "Duration:"   "$elapsed_s"
  printf "  %-14s %d\n"    "Total tx:"   "$tx"
  printf "  %-14s %s tx/s\n" "Throughput:" "$throughput"
  printf "  %-14s %d\n"    "Allowed:"    "$allowed"
  printf "  %-14s %d\n"    "Blocked:"    "$blocked"
  printf "  %-14s %d\n"    "Flagged:"    "$flagged"
  printf "  %-14s %dms\n"  "Avg latency:" "$avg_lat"
  echo ""
  echo "  Credit score changes:"
  local i=0
  while [ $i -lt $total ]; do
    local aid="${agents[$i]}" aname="${names[$i]}" init="${init_scores[$i]}"
    local final_score
    final_score=$(curl -s -H "Authorization: Bearer ${API_KEY}" "${BASE_URL}/agents/${aid}" 2>/dev/null | jq -r '.credit.score // 600')
    local delta=$((final_score - init))
    local sign=""
    [ "$delta" -gt 0 ] && sign="+"
    printf "    %-18s %3d → %3d  (%s%d)\n" "$aname" "$init" "$final_score" "$sign" "$delta"
    i=$((i + 1))
  done
  echo ""
  echo "  Dashboard: https://kredit.sh/dashboard/spend (toggle to Second view)"
  echo "  Log file:  $LOG_FILE"
  echo ""
}

cmd_logout() {
  local home="${HOME:-$(eval echo ~)}"
  if [ -f "$home/.kredit/config" ]; then
    rm "$home/.kredit/config"
    echo "Logged out. API key removed from ~/.kredit/config"
  else
    echo "Not logged in."
  fi
}

cmd_rules() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      local agent_id=""
      for arg in "$@"; do
        case "$arg" in
          --agent-id=*) agent_id="${arg#--agent-id=}" ;;
          --help) echo "Usage: kredit rules list --agent-id=ID"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$agent_id" ] && die "Missing --agent-id"
      api_request GET "/agents/${agent_id}/rules"
      ;;
    add)
      local agent_id="" name="" match="*" max_cost_per_txn=0 daily_spend_limit=0 hourly_rate_limit=0
      for arg in "$@"; do
        case "$arg" in
          --agent-id=*) agent_id="${arg#--agent-id=}" ;;
          --name=*) name="${arg#--name=}" ;;
          --match=*) match="${arg#--match=}" ;;
          --max-cost-per-txn=*) max_cost_per_txn="${arg#--max-cost-per-txn=}" ;;
          --daily-spend-limit=*) daily_spend_limit="${arg#--daily-spend-limit=}" ;;
          --hourly-rate-limit=*) hourly_rate_limit="${arg#--hourly-rate-limit=}" ;;
          --help) echo "Usage: kredit rules add --agent-id=ID --name=NAME --match=PATTERN [--max-cost-per-txn=N] [--daily-spend-limit=N] [--hourly-rate-limit=N]"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$agent_id" ] && die "Missing --agent-id"
      [ -z "$name" ] && die "Missing --name"
      api_request POST "/agents/${agent_id}/rules" "{\"name\":\"${name}\",\"match\":\"${match}\",\"max_cost_per_txn\":${max_cost_per_txn},\"daily_spend_limit\":${daily_spend_limit},\"hourly_rate_limit\":${hourly_rate_limit}}"
      ;;
    remove)
      local agent_id="" rule_id=""
      for arg in "$@"; do
        case "$arg" in
          --agent-id=*) agent_id="${arg#--agent-id=}" ;;
          --rule-id=*) rule_id="${arg#--rule-id=}" ;;
          --help) echo "Usage: kredit rules remove --agent-id=ID --rule-id=RULE_ID"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$agent_id" ] && die "Missing --agent-id"
      [ -z "$rule_id" ] && die "Missing --rule-id"
      api_request DELETE "/agents/${agent_id}/rules/${rule_id}"
      ;;
    --help|help)
      echo "Usage: kredit rules <list|add|remove>"
      echo ""
      echo "  kredit rules list --agent-id=ID"
      echo "  kredit rules add --agent-id=ID --name=NAME --match=PATTERN [--max-cost-per-txn=N] [--daily-spend-limit=N] [--hourly-rate-limit=N]"
      echo "  kredit rules remove --agent-id=ID --rule-id=RULE_ID"
      ;;
    "")
      die "Missing subcommand. Use: kredit rules <list|add|remove>"
      ;;
    *)
      die "Unknown rules subcommand: $subcmd"
      ;;
  esac
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_check() {
  local agent_id="" action="" estimated_cost="" type="api_call"

  for arg in "$@"; do
    case "$arg" in
      --agent-id=*) agent_id="${arg#--agent-id=}" ;;
      --action=*) action="${arg#--action=}" ;;
      --estimated-cost=*) estimated_cost="${arg#--estimated-cost=}" ;;
      --type=*) type="${arg#--type=}" ;;
      --help) echo "Usage: kredit check --agent-id=ID --action=ACTION --estimated-cost=COST [--type=TYPE]"; echo "  TYPE: api_call (default), compute, data, tool, other"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$agent_id" ] && die "Missing --agent-id"
  [ -z "$action" ] && die "Missing --action"
  [ -z "$estimated_cost" ] && die "Missing --estimated-cost"

  case "$type" in
    api_call|compute|data|tool|other) ;;
    *) die "Invalid --type: $type. Valid values: api_call, compute, data, tool, other" ;;
  esac

  api_request POST "/check" "{\"agent_id\":\"${agent_id}\",\"action\":\"${action}\",\"estimated_cost\":${estimated_cost},\"type\":\"${type}\"}"
}

cmd_report() {
  local transaction_id="" outcome="" actual_cost=""

  for arg in "$@"; do
    case "$arg" in
      --transaction-id=*) transaction_id="${arg#--transaction-id=}" ;;
      --outcome=*) outcome="${arg#--outcome=}" ;;
      --actual-cost=*) actual_cost="${arg#--actual-cost=}" ;;
      --help) echo "Usage: kredit report --transaction-id=ID --outcome=OUTCOME [--actual-cost=COST]"; echo "  OUTCOME: success, failure, partial"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$transaction_id" ] && die "Missing --transaction-id"
  [ -z "$outcome" ] && die "Missing --outcome"

  local body="{\"transaction_id\":\"${transaction_id}\",\"outcome\":\"${outcome}\""
  if [ -n "$actual_cost" ]; then
    body="${body},\"actual_cost\":${actual_cost}"
  fi
  body="${body}}"

  api_request POST "/report" "$body"
}

cmd_agents() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      local org_id=""
      for arg in "$@"; do
        case "$arg" in
          --org-id=*) org_id="${arg#--org-id=}" ;;
          --help) echo "Usage: kredit agents list [--org-id=ORG_ID]"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      if [ -n "$org_id" ]; then
        api_request GET "/agents?org_id=${org_id}"
      else
        api_request GET "/agents"
      fi
      ;;
    create)
      local org_name="" name=""
      for arg in "$@"; do
        case "$arg" in
          --org-name=*) org_name="${arg#--org-name=}" ;;
          --name=*) name="${arg#--name=}" ;;
          --help) echo "Usage: kredit agents create --org-name=ORG_NAME --name=AGENT_NAME"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$org_name" ] && die "Missing --org-name"
      [ -z "$name" ] && die "Missing --name"
      api_request POST "/agents" "{\"org_name\":\"${org_name}\",\"name\":\"${name}\"}"
      ;;
    --help|help)
      echo "Usage: kredit agents <list|create>"
      echo ""
      echo "  kredit agents list [--org-id=ORG_ID]"
      echo "  kredit agents create --org-name=ORG_NAME --name=AGENT_NAME"
      ;;
    "")
      die "Missing subcommand. Use: kredit agents <list|create>"
      ;;
    *)
      die "Unknown agents subcommand: $subcmd"
      ;;
  esac
}

cmd_orgs() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)
      api_request GET "/orgs"
      ;;
    create)
      local name=""
      for arg in "$@"; do
        case "$arg" in
          --name=*) name="${arg#--name=}" ;;
          --help) echo "Usage: kredit orgs create --name=ORG_NAME"; return 0 ;;
          *) die "Unknown argument: $arg" ;;
        esac
      done
      [ -z "$name" ] && die "Missing --name"
      api_request POST "/orgs" "{\"name\":\"${name}\"}"
      ;;
    --help|help)
      echo "Usage: kredit orgs <list|create>"
      echo ""
      echo "  kredit orgs list"
      echo "  kredit orgs create --name=ORG_NAME"
      ;;
    "")
      die "Missing subcommand. Use: kredit orgs <list|create>"
      ;;
    *)
      die "Unknown orgs subcommand: $subcmd"
      ;;
  esac
}

cmd_score() {
  local agent_id=""

  for arg in "$@"; do
    case "$arg" in
      --agent-id=*) agent_id="${arg#--agent-id=}" ;;
      --help) echo "Usage: kredit score --agent-id=ID"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$agent_id" ] && die "Missing --agent-id"
  api_request GET "/agents/${agent_id}/score"
}

cmd_wallet() {
  local agent_id=""

  for arg in "$@"; do
    case "$arg" in
      --agent-id=*) agent_id="${arg#--agent-id=}" ;;
      --help) echo "Usage: kredit wallet --agent-id=ID"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$agent_id" ] && die "Missing --agent-id"
  api_request GET "/wallets/${agent_id}"
}

show_help() {
  cat <<'HELP'
kredit — CLI for the Kredit financial risk management API

Usage:
  kredit <command> [options]

Commands:
  login     Authenticate and create an API key
  logout    Remove saved API key
  demo      Run a 1-hour simulation with sample agents
  rules     Manage agent rules (list, add, remove)
  check     Run a risk check before executing an action
  report    Report the outcome of an action
  agents    Manage agents (list, create)
  orgs      Manage organizations (list, create)
  score     Get credit score for an agent
  wallet    Get wallet info for an agent

Options:
  --help      Show help for a command
  --version   Print version

Examples:
  kredit check --agent-id=agt_8f3k2m --action=serp_api.search --estimated-cost=1 --type=api_call
  kredit report --transaction-id=txn_abc --outcome=success --actual-cost=1
  kredit agents list --org-id=org_123
  kredit agents create --org-name=research-team --name=bot-01
  kredit rules add --agent-id=ID --name="OpenAI" --match="openai.*" --max-cost-per-txn=5 --daily-spend-limit=100 --hourly-rate-limit=50
  kredit orgs create --name=research-team
  kredit score --agent-id=agt_8f3k2m
  kredit wallet --agent-id=agt_8f3k2m

Environment:
  KREDIT_API_KEY   API key (or set in ~/.kredit/config as api_key=...)
  KREDIT_API_URL   Base URL (default: https://api.kredit.sh)
HELP
}

# ── Main dispatch ────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-}"
  shift 2>/dev/null || true

  case "$cmd" in
    login)    cmd_login "$@" ;;
    logout)   cmd_logout "$@" ;;
    demo)     cmd_demo "$@" ;;
    check)    cmd_check "$@" ;;
    report)   cmd_report "$@" ;;
    agents)   cmd_agents "$@" ;;
    rules)    cmd_rules "$@" ;;
    orgs)     cmd_orgs "$@" ;;
    score)    cmd_score "$@" ;;
    wallet)   cmd_wallet "$@" ;;
    --help|-h|help) show_help ;;
    --version|-v) echo "kredit $VERSION" ;;
    "")
      show_help
      exit 1
      ;;
    *)
      die "Unknown command: $cmd. Run 'kredit --help' for usage."
      ;;
  esac
}

main "$@"
