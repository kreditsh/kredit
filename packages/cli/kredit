cmd_score() {
  local agent=""

  for arg in "$@"; do
    case "$arg" in
      --agent=*) agent="${arg#--agent=}" ;;
      --help) echo "Usage: kredit score --agent=AGT_ID"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
  done

  [ -z "$agent" ] && die "Missing --agent"
  api_request GET "/agents/${agent}/score"
}

cmd_wallet() {
  local agent=""

  for arg in "$@"; do
    case "$arg" in
      --agent=*) agent="${arg#--agent=}" ;;
      --help) echo "Usage: kredit wallet --agent=AGT_ID"; return 0 ;;
      *) die "Unknown argument: $arg" ;;
    esac
