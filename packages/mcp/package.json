{
  "name": "kredit-mcp",
  "version": "0.3.0",
  "description": "MCP server for Kredit — bring agent spend controls to Claude Code and Claude Desktop",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kredit-mcp": "./bin/kredit-mcp"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ test/",
    "format": "biome format --write src/ test/"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "mcp",
    "kredit",
    "claude",
    "agent",
    "risk"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.5.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
